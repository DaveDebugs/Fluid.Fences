<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <!-- These colors will be dynamically replaced by our JSON ThemeEngine -->
    <Color x:Key="CustomBackgroundColor">#01000000</Color>
    <SolidColorBrush x:Key="CustomBackgroundBrush" Color="{DynamicResource CustomBackgroundColor}" />

    <Color x:Key="CustomHeaderColor">#22000000</Color>
    <SolidColorBrush x:Key="CustomHeaderBrush" Color="{DynamicResource CustomHeaderColor}" />

    <Color x:Key="CustomFontColor">#FFFFFFFF</Color>
    <SolidColorBrush x:Key="CustomFontBrush" Color="{DynamicResource CustomFontColor}" />

    <Color x:Key="CustomAccentColor">#0078D7</Color>
    <SolidColorBrush x:Key="CustomAccentBrush" Color="{DynamicResource CustomAccentColor}" />

    <CornerRadius x:Key="CustomCornerRadius">8</CornerRadius>
</ResourceDictionary>
