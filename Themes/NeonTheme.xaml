<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation" xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <SolidColorBrush x:Key="ThemeHeaderBrush" Color="#AAFF0099"/>
    <SolidColorBrush x:Key="ThemeBorderBrush" Color="#FF00FFCC"/>
    <SolidColorBrush x:Key="ThemeTextBrush" Color="#FFDAFFDE"/>

    <DropShadowEffect x:Key="NeonGlowEffect" Color="#FF00FFCC" BlurRadius="15" ShadowDepth="0" Opacity="0.8"/>

    <Style x:Key="ActiveFenceBorderStyle" TargetType="Border">
        <Setter Property="BorderBrush" Value="{DynamicResource ThemeBorderBrush}"/>
        <Setter Property="BorderThickness" Value="1"/>
        <Setter Property="CornerRadius" Value="8"/>
        <Setter Property="Effect" Value="{StaticResource NeonGlowEffect}"/>
    </Style>

    <Style x:Key="ActiveTitleStyle" TargetType="TextBlock">
        <Setter Property="FontFamily" Value="Segoe UI Variable, Segoe UI, Arial"/>
        <Setter Property="FontWeight" Value="Bold"/>
        <Setter Property="Foreground" Value="{DynamicResource ThemeTextBrush}"/>
        <Setter Property="FontSize" Value="13"/>
    </Style>
</ResourceDictionary>