<Window
    x:Class="DesktopFences.MainWindow"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:ui="http://schemas.lepo.co/wpfui/2022/xaml"
    Title="Fluid Fence"
    Width="250"
    Height="300"
    AllowDrop="True"
    AllowsTransparency="True"
    Background="Transparent"
    Deactivated="Window_Deactivated"
    DragEnter="Window_DragEnter"
    DragLeave="Window_DragLeave"
    DragOver="Window_DragOver"
    Drop="Window_Drop"
    FontFamily="{DynamicResource CustomFontFamily}"
    Loaded="Window_Loaded"
    MouseEnter="Window_MouseEnter"
    MouseLeave="Window_MouseLeave"
    ShowInTaskbar="False"
    Topmost="False"
    WindowStyle="None">

    <Window.Resources>
        <Style x:Key="FenceScrollThumb" TargetType="Thumb">
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Thumb">
                        <Border
                            x:Name="ThumbBorder"
                            Margin="2,0,2,0"
                            Background="{DynamicResource CustomScrollThumbBrush}"
                            CornerRadius="{DynamicResource CustomCornerRadiusSmall}" />
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="ThumbBorder" Property="Background" Value="{DynamicResource CustomScrollThumbHoverBrush}" />
                            </Trigger>
                            <Trigger Property="IsDragging" Value="True">
                                <Setter TargetName="ThumbBorder" Property="Background" Value="{DynamicResource CustomScrollThumbActiveBrush}" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style TargetType="ScrollBar">
            <Setter Property="Width" Value="10" />
            <Setter Property="Background" Value="Transparent" />
            <Setter Property="BorderThickness" Value="0" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ScrollBar">
                        <Grid Background="Transparent">
                            <Track x:Name="PART_Track" IsDirectionReversed="true">
                                <Track.DecreaseRepeatButton>
                                    <RepeatButton
                                        Command="{x:Static ScrollBar.PageUpCommand}"
                                        Focusable="False"
                                        Opacity="0" />
                                </Track.DecreaseRepeatButton>
                                <Track.Thumb>
                                    <Thumb Style="{StaticResource FenceScrollThumb}" />
                                </Track.Thumb>
                                <Track.IncreaseRepeatButton>
                                    <RepeatButton
                                        Command="{x:Static ScrollBar.PageDownCommand}"
                                        Focusable="False"
                                        Opacity="0" />
                                </Track.IncreaseRepeatButton>
                            </Track>
                        </Grid>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="TabListBoxItem" TargetType="ListBoxItem">
            <Setter Property="Background" Value="Transparent" />
            <Setter Property="Foreground" Value="{DynamicResource CustomTextSecondaryBrush}" />
            <Setter Property="Padding" Value="12,7" />
            <Setter Property="Margin" Value="0,0,4,0" />
            <Setter Property="Cursor" Value="Hand" />
            <Setter Property="FontFamily" Value="{DynamicResource CustomFontFamily}" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ListBoxItem">
                        <Grid>
                            <Border x:Name="Fill"
                                    Background="{TemplateBinding Background}"
                                    CornerRadius="{DynamicResource CustomCornerRadiusSmall}">
                                <ContentPresenter
                                    Margin="{TemplateBinding Padding}"
                                    HorizontalAlignment="Center"
                                    VerticalAlignment="Center" />
                            </Border>

                            <Border x:Name="FocusRing"
                                    BorderBrush="{DynamicResource CustomFocusRingBrush}"
                                    BorderThickness="2"
                                    CornerRadius="{DynamicResource CustomCornerRadiusSmall}"
                                    SnapsToDevicePixels="True"
                                    Visibility="Collapsed" />
                        </Grid>

                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Fill" Property="Background" Value="{DynamicResource CustomSurfaceHoverBrush}" />
                                <Setter Property="Foreground" Value="{DynamicResource CustomTextPrimaryBrush}" />
                            </Trigger>
                            <Trigger Property="IsSelected" Value="True">
                                <Setter TargetName="Fill" Property="Background" Value="{DynamicResource CustomSurfaceSelectedBrush}" />
                                <Setter Property="Foreground" Value="{DynamicResource CustomTextPrimaryBrush}" />
                                <Setter Property="FontWeight" Value="SemiBold" />
                            </Trigger>

                            <Trigger Property="IsKeyboardFocused" Value="True">
                                <Setter TargetName="FocusRing" Property="Visibility" Value="Visible" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="HeaderGlyphButton" TargetType="Button">
            <Setter Property="Background" Value="Transparent" />
            <Setter Property="BorderThickness" Value="0" />
            <Setter Property="Cursor" Value="Hand" />
            <Setter Property="Focusable" Value="True" />
            <Setter Property="Width" Value="32" />
            <Setter Property="Height" Value="28" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Grid>
                            <Border x:Name="Fill"
                                    Background="{TemplateBinding Background}"
                                    CornerRadius="{DynamicResource CustomCornerRadiusSmall}" />
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center" />
                            <Border x:Name="FocusRing"
                                    BorderBrush="{DynamicResource CustomFocusRingBrush}"
                                    BorderThickness="2"
                                    CornerRadius="{DynamicResource CustomCornerRadiusSmall}"
                                    SnapsToDevicePixels="True"
                                    Visibility="Collapsed" />
                        </Grid>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Fill" Property="Background" Value="{DynamicResource CustomSurfaceHoverBrush}" />
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="Fill" Property="Background" Value="{DynamicResource CustomSurfaceSelectedBrush}" />
                            </Trigger>
                            <Trigger Property="IsKeyboardFocused" Value="True">
                                <Setter TargetName="FocusRing" Property="Visibility" Value="Visible" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

    </Window.Resources>

    <Border
        x:Name="MainBorder"
        Background="{DynamicResource CustomBackgroundBrush}"
        CornerRadius="{DynamicResource CustomCornerRadius}">
        <Grid x:Name="MainGrid" Background="Transparent">
            <Grid.RowDefinitions>
                <RowDefinition x:Name="HeaderRowTop" Height="35" />
                <RowDefinition Height="*" />
                <RowDefinition x:Name="HeaderRowBottom" Height="0" />
            </Grid.RowDefinitions>
            <Grid.ColumnDefinitions>
                <ColumnDefinition x:Name="HeaderColLeft" Width="0" />
                <ColumnDefinition Width="*" />
                <ColumnDefinition x:Name="HeaderColRight" Width="0" />
            </Grid.ColumnDefinitions>

            <Grid Grid.Row="0" Grid.RowSpan="3" Grid.Column="0" Grid.ColumnSpan="3">
                <Grid.OpacityMask>
                    <VisualBrush>
                        <VisualBrush.Visual>
                            <Border Background="White" CornerRadius="{DynamicResource CustomCornerRadius}"
                                    Width="{Binding ActualWidth, RelativeSource={RelativeSource AncestorType=Grid}}"
                                    Height="{Binding ActualHeight, RelativeSource={RelativeSource AncestorType=Grid}}" />
                        </VisualBrush.Visual>
                    </VisualBrush>
                </Grid.OpacityMask>
                <MediaElement
                    x:Name="BackgroundMedia"
                    LoadedBehavior="Manual"
                    UnloadedBehavior="Manual"
                    Stretch="UniformToFill"
                    IsMuted="True"
                    MediaEnded="BackgroundMedia_MediaEnded"
                    Visibility="Hidden" />
            </Grid>

            <Border
                x:Name="HeaderBorder"
                Grid.Row="0"
                Grid.Column="0"
                Grid.ColumnSpan="3"
                Background="{DynamicResource CustomHeaderBrush}"
                CornerRadius="{DynamicResource CustomCornerRadius}"
                Margin="0,0,0,0"
                Cursor="Hand"
                MouseLeftButtonDown="Header_MouseLeftButtonDown"
                MouseLeftButtonUp="Header_MouseLeftButtonUp"
                MouseMove="Header_MouseMove">

                <Border.ContextMenu>
                    <ContextMenu x:Name="HeaderContextMenu">
                        <MenuItem Header="Create New...">
                            <MenuItem.Icon>
                                <ui:SymbolIcon Symbol="Add24" />
                            </MenuItem.Icon>
                            <MenuItem Click="Menu_NewFence_Click" Header="Empty Fence" Icon="{ui:SymbolIcon Symbol=Board24}" />
                            <MenuItem Click="Menu_NewPortal_Click" Header="Folder Portal (Mirror PC Folder)" Icon="{ui:SymbolIcon Symbol=Folder24}" />
                            <Separator />
                            <MenuItem Click="Menu_NewTab_Click" Header="New Tab Inside This Fence" Icon="{ui:SymbolIcon Symbol=Tab24}" />
                        </MenuItem>

                        <MenuItem Click="Menu_AutoOrganize_Click" Header="Auto Organize (Pull from Desktop)" Icon="{ui:SymbolIcon Symbol=Desktop24}" />
                        <Separator />

                        <MenuItem
                            x:Name="MenuRollUpFence"
                            Click="Menu_RollUp_Click"
                            Header="Roll-up Fence"
                            Icon="{ui:SymbolIcon Symbol=ChevronUp24}" />

                        <MenuItem Header="View">
                            <MenuItem.Icon>
                                <ui:SymbolIcon Symbol="Eye24" />
                            </MenuItem.Icon>
                            <MenuItem Header="Icon Size">
                                <MenuItem Click="Menu_IconSize_Click" Header="Small" Tag="32" />
                                <MenuItem Click="Menu_IconSize_Click" Header="Medium" Tag="48" />
                                <MenuItem Click="Menu_IconSize_Click" Header="Large" Tag="64" />
                            </MenuItem>
                            <MenuItem Header="Sort By">
                                <MenuItem Click="Menu_Sort_Click" Header="Name" Tag="Name" />
                                <MenuItem Click="Menu_Sort_Click" Header="Size" Tag="Size" />
                                <MenuItem Click="Menu_Sort_Click" Header="Item Type" Tag="Type" />
                                <MenuItem Click="Menu_Sort_Click" Header="Date Modified" Tag="DateMod" />
                                <MenuItem Click="Menu_Sort_Click" Header="Date Created" Tag="DateCre" />
                            </MenuItem>
                        </MenuItem>

                        <Separator />
                        <MenuItem x:Name="MenuEditColor" Click="Menu_EditColor_Click" Header="Edit Color..." Icon="{ui:SymbolIcon Symbol=Color24}" />
                        <MenuItem x:Name="MenuSettings" Click="Menu_Settings_Click" Header="Settings..." Icon="{ui:SymbolIcon Symbol=Settings24}" />
                        <Separator />
                        <MenuItem x:Name="MenuDeleteFence" Click="Menu_DeleteFence_Click" Foreground="{DynamicResource CustomErrorBrush}" Header="Delete Fence" Icon="{ui:SymbolIcon Symbol=Delete24}" InputGestureText="Del" />
                    </ContextMenu>
                </Border.ContextMenu>

                <Grid x:Name="HeaderGrid">
                    <StackPanel
                        x:Name="TitleStack"
                        Margin="15,0"
                        HorizontalAlignment="Left"
                        VerticalAlignment="Center"
                        Orientation="Horizontal">
                        <TextBlock
                            x:Name="TitleText"
                            Margin="10,0,10,0"
                            VerticalAlignment="Center"
                            FontFamily="{DynamicResource CustomFontFamily}"
                            FontSize="12"
                            FontWeight="SemiBold"
                            Foreground="{DynamicResource CustomTextPrimaryBrush}"
                            Text="{Binding FolderName}"
                            TextTrimming="CharacterEllipsis"
                            MouseLeftButtonDown="TitleText_MouseLeftButtonDown" />
                    </StackPanel>

                    <StackPanel
                        HorizontalAlignment="Right"
                        VerticalAlignment="Center"
                        Orientation="Horizontal">

                        <Button
                            x:Name="SearchIcon"
                            Margin="0,0,2,0"
                            Click="SearchIcon_Click"
                            Style="{StaticResource HeaderGlyphButton}"
                            AutomationProperties.Name="Search this fence"
                            ToolTip="Search this fence (Ctrl+F)">
                            <Path
                                Width="14"
                                Height="14"
                                Data="M 15.5 14 L 10.71 9.21 C 11.52 8.08 12 6.6 12 5 C 12 2.24 9.76 0 7 0 C 4.24 0 2 2.24 2 5 C 2 7.76 4.24 10 7 10 C 8.6 10 10.08 9.52 11.21 8.71 L 16 13.5 L 15.5 14 Z M 7 8 C 5.34 8 4 6.66 4 5 C 4 3.34 5.34 2 7 2 C 8.66 2 10 3.34 10 5 C 10 6.66 8.66 8 7 8 Z"
                                Fill="{DynamicResource CustomGlyphBrush}"
                                Stretch="Uniform" />
                        </Button>

                        <Button
                            x:Name="MenuIcon"
                            Margin="0,0,4,0"
                            Click="MenuIcon_Click"
                            Style="{StaticResource HeaderGlyphButton}"
                            AutomationProperties.Name="Fence menu"
                            ToolTip="Fence menu (F10)">
                            <Path
                                Width="16"
                                Height="16"
                                Data="M 2 4 h 12 v 2 H 2 Z m 0 5 h 12 v 2 H 2 Z m 0 5 h 12 v 2 H 2 Z"
                                Fill="{DynamicResource CustomGlyphBrush}"
                                Stretch="Uniform" />
                        </Button>
                    </StackPanel>
                </Grid>
            </Border>

            <TextBox
                x:Name="SearchBox"
                Grid.Row="0"
                Grid.Column="0"
                Grid.ColumnSpan="3"
                Width="160"
                Height="26"
                Margin="0,4,35,0"
                Padding="5,2"
                HorizontalAlignment="Right"
                VerticalAlignment="Top"
                Panel.ZIndex="999"
                Background="{DynamicResource CustomSurfaceSubtleBrush}"
                BorderBrush="{DynamicResource CustomBorderBrush}"
                BorderThickness="1"
                CaretBrush="{DynamicResource CustomTextPrimaryBrush}"
                FontFamily="{DynamicResource CustomFontFamily}"
                Foreground="{DynamicResource CustomTextPrimaryBrush}"
                AutomationProperties.Name="Filter items in this fence"
                KeyDown="SearchBox_KeyDown"
                LostFocus="SearchBox_LostFocus"
                TextChanged="SearchBox_TextChanged"
                Visibility="Collapsed" />

            <Grid
                Grid.Row="1"
                Grid.Column="1"
                Margin="0,5,0,0">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="*" />
                </Grid.RowDefinitions>

                <Grid
                    x:Name="TabBarContainer"
                    Grid.Row="0"
                    Margin="10,0,10,5">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>

                    <ScrollViewer
                        VerticalAlignment="Center"
                        HorizontalScrollBarVisibility="Hidden"
                        VerticalScrollBarVisibility="Disabled">
                        <ListBox
                            x:Name="TabBar"
                            Background="Transparent"
                            BorderThickness="0"
                            ItemContainerStyle="{StaticResource TabListBoxItem}">
                            <ListBox.ItemsPanel>
                                <ItemsPanelTemplate>
                                    <StackPanel Orientation="Horizontal" />
                                </ItemsPanelTemplate>
                            </ListBox.ItemsPanel>
                        </ListBox>
                    </ScrollViewer>

                    <Button
                        x:Name="AddTabBtn"
                        Grid.Column="1"
                        Width="28"
                        Height="28"
                        Margin="4,0,0,0"
                        VerticalAlignment="Center"
                        Click="AddTabBtn_Click"
                        Content="+"
                        FontSize="16"
                        Foreground="{DynamicResource CustomTextSecondaryBrush}"
                        Style="{StaticResource HeaderGlyphButton}"
                        AutomationProperties.Name="New tab"
                        ToolTip="New tab (Ctrl+T)" />
                </Grid>

                <ScrollViewer
                    Grid.Row="1"
                    HorizontalScrollBarVisibility="Disabled"
                    VerticalScrollBarVisibility="Auto">
                    <Grid>
                        <Canvas x:Name="SelectionCanvas">
                            <Border
                                x:Name="SelectionBox"
                                Background="{DynamicResource CustomSelectionFillBrush}"
                                BorderBrush="{DynamicResource CustomSelectionStrokeBrush}"
                                BorderThickness="1"
                                Visibility="Collapsed" />
                        </Canvas>
                        <WrapPanel
                            x:Name="IconPanel"
                            Margin="5"
                            Background="Transparent"
                            MouseLeftButtonDown="IconPanel_MouseLeftButtonDown"
                            MouseLeftButtonUp="IconPanel_MouseLeftButtonUp"
                            MouseMove="IconPanel_MouseMove" />
                    </Grid>
                </ScrollViewer>
            </Grid>

            <Rectangle
                Grid.Row="0"
                Grid.RowSpan="3"
                Grid.Column="0"
                Grid.ColumnSpan="3"
                Width="4"
                HorizontalAlignment="Left"
                Panel.ZIndex="1000"
                Cursor="SizeWE"
                Fill="Transparent"
                MouseLeftButtonDown="Resize_Left" />
            <Rectangle
                Grid.Row="0"
                Grid.RowSpan="3"
                Grid.Column="0"
                Grid.ColumnSpan="3"
                Width="4"
                HorizontalAlignment="Right"
                Panel.ZIndex="1000"
                Cursor="SizeWE"
                Fill="Transparent"
                MouseLeftButtonDown="Resize_Right" />
            <Rectangle
                Grid.Row="0"
                Grid.RowSpan="3"
                Grid.Column="0"
                Grid.ColumnSpan="3"
                Height="4"
                VerticalAlignment="Top"
                Panel.ZIndex="1000"
                Cursor="SizeNS"
                Fill="Transparent"
                MouseLeftButtonDown="Resize_Top" />
            <Rectangle
                Grid.Row="0"
                Grid.RowSpan="3"
                Grid.Column="0"
                Grid.ColumnSpan="3"
                Height="4"
                VerticalAlignment="Bottom"
                Panel.ZIndex="1000"
                Cursor="SizeNS"
                Fill="Transparent"
                MouseLeftButtonDown="Resize_Bottom" />

            <Rectangle
                Grid.Row="0"
                Grid.RowSpan="3"
                Grid.Column="0"
                Grid.ColumnSpan="3"
                Width="6"
                Height="6"
                HorizontalAlignment="Left"
                VerticalAlignment="Top"
                Panel.ZIndex="1001"
                Cursor="SizeNWSE"
                Fill="Transparent"
                MouseLeftButtonDown="Resize_TopLeft" />
            <Rectangle
                Grid.Row="0"
                Grid.RowSpan="3"
                Grid.Column="0"
                Grid.ColumnSpan="3"
                Width="6"
                Height="6"
                HorizontalAlignment="Right"
                VerticalAlignment="Top"
                Panel.ZIndex="1001"
                Cursor="SizeNESW"
                Fill="Transparent"
                MouseLeftButtonDown="Resize_TopRight" />
            <Rectangle
                Grid.Row="0"
                Grid.RowSpan="3"
                Grid.Column="0"
                Grid.ColumnSpan="3"
                Width="6"
                Height="6"
                HorizontalAlignment="Left"
                VerticalAlignment="Bottom"
                Panel.ZIndex="1001"
                Cursor="SizeNESW"
                Fill="Transparent"
                MouseLeftButtonDown="Resize_BottomLeft" />
            <Rectangle
                Grid.Row="0"
                Grid.RowSpan="3"
                Grid.Column="0"
                Grid.ColumnSpan="3"
                Width="6"
                Height="6"
                HorizontalAlignment="Right"
                VerticalAlignment="Bottom"
                Panel.ZIndex="1001"
                Cursor="SizeNWSE"
                Fill="Transparent"
                MouseLeftButtonDown="Resize_BottomRight" />
        </Grid>
    </Border>
</Window>
