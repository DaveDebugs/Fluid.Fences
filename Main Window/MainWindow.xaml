<Window
    x:Class="DesktopFences.MainWindow"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    Title="Fence"
    Width="250"
    Height="300"
    AllowDrop="True"
    AllowsTransparency="True"
    Background="Transparent"
    Deactivated="Window_Deactivated"
    DragEnter="Window_DragEnter"
    DragLeave="Window_DragLeave"
    DragOver="Window_DragOver"
    Drop="Window_Drop"
    Loaded="Window_Loaded"
    MouseEnter="Window_MouseEnter"
    MouseLeave="Window_MouseLeave"
    ShowInTaskbar="False"
    WindowStyle="None">

    <Window.Resources>
        <Style x:Key="ModernScrollThumb" TargetType="{x:Type Thumb}">
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="{x:Type Thumb}">
                        <Border
                            Margin="0,2,2,2"
                            Background="#66FFFFFF"
                            CornerRadius="3" />
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style TargetType="{x:Type ScrollBar}">
            <Setter Property="Background" Value="Transparent" />
            <Setter Property="Width" Value="6" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="{x:Type ScrollBar}">
                        <Grid Background="{TemplateBinding Background}">
                            <Track x:Name="PART_Track" IsDirectionReversed="True">
                                <Track.DecreaseRepeatButton>
                                    <RepeatButton
                                        Command="ScrollBar.PageUpCommand"
                                        Focusable="False"
                                        Opacity="0" />
                                </Track.DecreaseRepeatButton>
                                <Track.IncreaseRepeatButton>
                                    <RepeatButton
                                        Command="ScrollBar.PageDownCommand"
                                        Focusable="False"
                                        Opacity="0" />
                                </Track.IncreaseRepeatButton>
                                <Track.Thumb>
                                    <Thumb Style="{StaticResource ModernScrollThumb}" />
                                </Track.Thumb>
                            </Track>
                        </Grid>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Geometry x:Key="SubmenuArrowGeometry">M 0 0 L 4 3.5 L 0 7 Z</Geometry>

        <Style TargetType="{x:Type ContextMenu}">
            <Setter Property="SnapsToDevicePixels" Value="True" />
            <Setter Property="Grid.IsSharedSizeScope" Value="True" />
            <Setter Property="HasDropShadow" Value="True" />
            <Setter Property="Background" Value="#01FFFFFF" />
            <Setter Property="BorderThickness" Value="0" />
            <Setter Property="Padding" Value="2" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="{x:Type ContextMenu}">
                        <Border
                            Background="#1A1A1A1A"
                            BorderBrush="#33FFFFFF"
                            BorderThickness="1"
                            CornerRadius="8">
                            <ScrollViewer
                                x:Name="DropDownScrollViewer"
                                Margin="1"
                                Padding="{TemplateBinding Padding}"
                                Focusable="False">
                                <ItemsPresenter KeyboardNavigation.TabNavigation="Cycle" SnapsToDevicePixels="{TemplateBinding SnapsToDevicePixels}" />
                            </ScrollViewer>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style TargetType="{x:Type Separator}">
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="{x:Type Separator}">
                        <Border
                            Height="1"
                            Margin="26,4,4,4"
                            Background="#33FFFFFF" />
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style TargetType="{x:Type MenuItem}">
            <Setter Property="Background" Value="Transparent" />
            <Setter Property="Foreground" Value="White" />
            <Setter Property="FontFamily" Value="Segoe UI Variable Text, Segoe UI, Arial" />
            <Setter Property="FontSize" Value="12" />
            <Setter Property="Height" Value="28" />
            <Setter Property="VerticalContentAlignment" Value="Center" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="{x:Type MenuItem}">
                        <Border
                            x:Name="templateRoot"
                            Margin="2,1"
                            Background="{TemplateBinding Background}"
                            BorderThickness="0"
                            CornerRadius="4">
                            <Grid Margin="8,0,8,0" VerticalAlignment="Center">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="Auto" />
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="Auto" />
                                    <ColumnDefinition Width="Auto" />
                                </Grid.ColumnDefinitions>

                                <ContentPresenter
                                    x:Name="Icon"
                                    Margin="0,0,8,0"
                                    VerticalAlignment="Center"
                                    ContentSource="Icon"
                                    SnapsToDevicePixels="{TemplateBinding SnapsToDevicePixels}"
                                    Visibility="Collapsed" />
                                <ContentPresenter
                                    Grid.Column="1"
                                    VerticalAlignment="Center"
                                    ContentSource="Header"
                                    RecognizesAccessKey="True"
                                    SnapsToDevicePixels="{TemplateBinding SnapsToDevicePixels}" />
                                <Path
                                    x:Name="RightArrow"
                                    Grid.Column="3"
                                    Margin="8,0,0,0"
                                    VerticalAlignment="Center"
                                    Data="{StaticResource SubmenuArrowGeometry}"
                                    Fill="White"
                                    Visibility="Collapsed" />

                                <Popup
                                    x:Name="PART_Popup"
                                    AllowsTransparency="True"
                                    Focusable="False"
                                    HorizontalOffset="4"
                                    IsOpen="{Binding IsSubmenuOpen, RelativeSource={RelativeSource TemplatedParent}}"
                                    Placement="Right"
                                    VerticalOffset="-4">
                                    <Border
                                        x:Name="SubMenuBorder"
                                        Padding="2"
                                        Background="#01FFFFFF"
                                        BorderThickness="0">
                                        <Border
                                            Background="#1A1A1A1A"
                                            BorderBrush="#33FFFFFF"
                                            BorderThickness="1"
                                            CornerRadius="8">
                                            <Border.Effect>
                                                <DropShadowEffect
                                                    BlurRadius="10"
                                                    Direction="315"
                                                    Opacity="0.6"
                                                    ShadowDepth="4"
                                                    Color="Black" />
                                            </Border.Effect>
                                            <ScrollViewer
                                                x:Name="SubMenuScrollViewer"
                                                Margin="1"
                                                Padding="2"
                                                SnapsToDevicePixels="True"
                                                VerticalScrollBarVisibility="Auto">
                                                <Grid RenderOptions.ClearTypeHint="Enabled">
                                                    <ItemsPresenter
                                                        x:Name="ItemsPresenter"
                                                        Grid.IsSharedSizeScope="True"
                                                        KeyboardNavigation.DirectionalNavigation="Cycle"
                                                        KeyboardNavigation.TabNavigation="Cycle"
                                                        SnapsToDevicePixels="{TemplateBinding SnapsToDevicePixels}" />
                                                </Grid>
                                            </ScrollViewer>
                                        </Border>
                                    </Border>
                                </Popup>
                            </Grid>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="Icon" Value="{x:Null}">
                                <Setter TargetName="Icon" Property="Visibility" Value="Collapsed" />
                            </Trigger>
                            <Trigger Property="IsHighlighted" Value="True">
                                <Setter TargetName="templateRoot" Property="Background" Value="#33FFFFFF" />
                            </Trigger>
                            <Trigger Property="Role" Value="SubmenuHeader">
                                <Setter TargetName="RightArrow" Property="Visibility" Value="Visible" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Window.Resources>

    <Border
        x:Name="MainBorder"
        Background="#B2000000"
        BorderThickness="0"
        CornerRadius="8">
        <Grid
            x:Name="MainGrid"
            Focusable="True"
            PreviewMouseLeftButtonDown="MainGrid_PreviewMouseLeftButtonDown">
            <Grid.RowDefinitions>
                <RowDefinition x:Name="HeaderRowTop" Height="35" />
                <RowDefinition Height="*" />
                <RowDefinition x:Name="HeaderRowBottom" Height="0" />
            </Grid.RowDefinitions>
            <Grid.ColumnDefinitions>
                <ColumnDefinition x:Name="HeaderColLeft" Width="0" />
                <ColumnDefinition Width="*" />
                <ColumnDefinition x:Name="HeaderColRight" Width="0" />
            </Grid.ColumnDefinitions>

            <Border
                x:Name="HeaderBorder"
                Grid.Row="0"
                Grid.Column="0"
                Grid.ColumnSpan="3"
                Background="#55000000"
                CornerRadius="8,8,0,0"
                Cursor="SizeAll"
                MouseLeftButtonDown="Header_MouseLeftButtonDown"
                MouseLeftButtonUp="Header_MouseLeftButtonUp"
                MouseMove="Header_MouseMove">
                <Border.ContextMenu>
                    <ContextMenu
                        x:Name="HeaderContextMenu"
                        MenuItem.SubmenuOpened="Submenu_Opened_ApplyBlur"
                        Opened="ContextMenu_Opened_ApplyBlur">
                        <MenuItem Click="Menu_NewFence_Click" Header="Create New Fence" />
                        <MenuItem Header="View">
                            <MenuItem Header="Icon Size">
                                <MenuItem
                                    Click="Menu_IconSize_Click"
                                    Header="Small (32px)"
                                    Tag="32" />
                                <MenuItem
                                    Click="Menu_IconSize_Click"
                                    Header="Medium (48px)"
                                    Tag="48" />
                                <MenuItem Header="Large (64px)" Tag="64" Click="Menu_IconSize_Click"/>
                            </MenuItem>
                            <Separator/>
                            

                            <MenuItem x:Name="MenuRollUpFence" Header="Roll-up Fence" IsCheckable="True" Click="Menu_RollUp_Click"/>

                            <Separator/>
                            <MenuItem Header="Copy Color" Click="Menu_CopyColor_Click"/>
                            <MenuItem Header="Edit Color..." Click="Menu_EditColor_Click"/>
                        </MenuItem>
                        <MenuItem Header="Sort by">
                            <MenuItem
                                Click="Menu_Sort_Click"
                                Header="None"
                                Tag="None" />
                            <Separator />
                            <MenuItem
                                Click="Menu_Sort_Click"
                                Header="Name"
                                Tag="Name" />
                            <MenuItem
                                Click="Menu_Sort_Click"
                                Header="Size"
                                Tag="Size" />
                            <MenuItem
                                Click="Menu_Sort_Click"
                                Header="Item Type"
                                Tag="Type" />
                            <MenuItem
                                Click="Menu_Sort_Click"
                                Header="Date Modified"
                                Tag="DateMod" />
                            <MenuItem
                                Click="Menu_Sort_Click"
                                Header="Date Created"
                                Tag="DateCre" />
                            <MenuItem
                                Click="Menu_Sort_Click"
                                Header="Date added to Fence"
                                Tag="DateAdd" />
                        </MenuItem>
                        <Separator />
                        <MenuItem Click="Menu_Settings_Click" Header="Settings" />
                        <MenuItem
                            Click="Menu_DeleteFence_Click"
                            Foreground="Red"
                            Header="Delete This Fence" />
                    </ContextMenu>
                </Border.ContextMenu>

                <Grid
                    x:Name="HeaderGrid"
                    Margin="10,0"
                    HorizontalAlignment="Stretch"
                    VerticalAlignment="Stretch">
                    <StackPanel
                        x:Name="TitleStack"
                        HorizontalAlignment="Center"
                        Background="Transparent"
                        MouseLeftButtonDown="TitleText_MouseLeftButtonDown"
                        Orientation="Horizontal">
                        <TextBlock
                            x:Name="MenuIcon"
                            Margin="0,0,10,0"
                            VerticalAlignment="Center"
                            Cursor="Hand"
                            FontSize="16"
                            Foreground="White"
                            MouseLeftButtonDown="MenuIcon_MouseLeftButtonDown"
                            Text="☰" />
                        <TextBlock
                            x:Name="TitleText"
                            VerticalAlignment="Center"
                            Cursor="IBeam"
                            FontFamily="Segoe UI Variable Text, Segoe UI"
                            FontSize="14"
                            FontWeight="SemiBold"
                            Foreground="White"
                            Text="Fluid Fence" />
                    </StackPanel>

                    <StackPanel
                        x:Name="SearchPanel"
                        HorizontalAlignment="Right"
                        VerticalAlignment="Center"
                        Background="Transparent"
                        Orientation="Horizontal">
                        <TextBox
                            x:Name="SearchBox"
                            Width="120"
                            Height="22"
                            Margin="0,0,8,0"
                            Padding="5,0"
                            VerticalContentAlignment="Center"
                            CaretBrush="White"
                            Foreground="White"
                            LostFocus="SearchBox_LostFocus"
                            TextChanged="SearchBox_TextChanged"
                            Visibility="Collapsed">
                            <TextBox.Template>
                                <ControlTemplate TargetType="TextBox">
                                    <Border
                                        Background="#33000000"
                                        BorderBrush="#55FFFFFF"
                                        BorderThickness="1"
                                        CornerRadius="4">
                                        <ScrollViewer x:Name="PART_ContentHost" Margin="0" />
                                    </Border>
                                </ControlTemplate>
                            </TextBox.Template>
                        </TextBox>
                        <TextBlock
                            x:Name="SearchIcon"
                            VerticalAlignment="Center"
                            Cursor="Hand"
                            FontSize="13"
                            Foreground="White"
                            MouseLeftButtonDown="SearchIcon_MouseLeftButtonDown"
                            Text="🔍" />
                    </StackPanel>
                </Grid>
            </Border>

            <Grid Grid.Row="1" Grid.Column="1">
                <ScrollViewer HorizontalScrollBarVisibility="Disabled" VerticalScrollBarVisibility="Auto">
                    <WrapPanel
                        x:Name="IconPanel"
                        Margin="10"
                        Background="#01000000"
                        MouseLeftButtonDown="IconPanel_MouseLeftButtonDown"
                        MouseLeftButtonUp="IconPanel_MouseLeftButtonUp"
                        MouseMove="IconPanel_MouseMove"
                        Orientation="Horizontal">
                        <TextBlock
                            Margin="10"
                            HorizontalAlignment="Center"
                            VerticalAlignment="Center"
                            Foreground="#88FFFFFF"
                            Text="Drop shortcuts here..." />
                    </WrapPanel>
                </ScrollViewer>
                <Canvas x:Name="SelectionCanvas" IsHitTestVisible="False">
                    <Rectangle
                        x:Name="SelectionBox"
                        Fill="#550078D7"
                        Stroke="#0078D7"
                        StrokeThickness="1"
                        Visibility="Collapsed" />
                </Canvas>
            </Grid>

            <Rectangle
                Grid.RowSpan="3"
                Grid.ColumnSpan="3"
                Width="6"
                HorizontalAlignment="Left"
                Cursor="SizeWE"
                Fill="Transparent"
                PreviewMouseLeftButtonDown="Resize_Left" />
            <Rectangle
                Grid.RowSpan="3"
                Grid.ColumnSpan="3"
                Width="6"
                HorizontalAlignment="Right"
                Cursor="SizeWE"
                Fill="Transparent"
                PreviewMouseLeftButtonDown="Resize_Right" />
            <Rectangle
                Grid.RowSpan="3"
                Grid.ColumnSpan="3"
                Height="6"
                VerticalAlignment="Top"
                Cursor="SizeNS"
                Fill="Transparent"
                PreviewMouseLeftButtonDown="Resize_Top" />
            <Rectangle
                Grid.RowSpan="3"
                Grid.ColumnSpan="3"
                Height="6"
                VerticalAlignment="Bottom"
                Cursor="SizeNS"
                Fill="Transparent"
                PreviewMouseLeftButtonDown="Resize_Bottom" />
            <Rectangle
                Grid.RowSpan="3"
                Grid.ColumnSpan="3"
                Width="14"
                Height="14"
                HorizontalAlignment="Left"
                VerticalAlignment="Top"
                Cursor="SizeNWSE"
                Fill="Transparent"
                PreviewMouseLeftButtonDown="Resize_TopLeft" />
            <Rectangle
                Grid.RowSpan="3"
                Grid.ColumnSpan="3"
                Width="14"
                Height="14"
                HorizontalAlignment="Right"
                VerticalAlignment="Top"
                Cursor="SizeNESW"
                Fill="Transparent"
                PreviewMouseLeftButtonDown="Resize_TopRight" />
            <Rectangle
                Grid.RowSpan="3"
                Grid.ColumnSpan="3"
                Width="14"
                Height="14"
                HorizontalAlignment="Left"
                VerticalAlignment="Bottom"
                Cursor="SizeNESW"
                Fill="Transparent"
                PreviewMouseLeftButtonDown="Resize_BottomLeft" />
            <Rectangle
                Grid.RowSpan="3"
                Grid.ColumnSpan="3"
                Width="14"
                Height="14"
                HorizontalAlignment="Right"
                VerticalAlignment="Bottom"
                Cursor="SizeNWSE"
                Fill="Transparent"
                PreviewMouseLeftButtonDown="Resize_BottomRight" />
        </Grid>
    </Border>
</Window>