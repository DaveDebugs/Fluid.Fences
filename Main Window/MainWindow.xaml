<Window
    x:Class="DesktopFences.MainWindow"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    Title="Fence"
    Width="250"
    Height="300"
    AllowDrop="True"
    AllowsTransparency="True"
    Background="Transparent"
    Drop="Window_Drop"
    Loaded="Window_Loaded"
    MouseEnter="Window_MouseEnter"
    MouseLeave="Window_MouseLeave"
    ShowInTaskbar="False"
    WindowStyle="None">

    <Window.Resources>
        <Style TargetType="Thumb">
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Thumb">
                        <Border Background="Transparent" />
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Window.Resources>

    <Border
        x:Name="MainBorder"
        Margin="10"
        Background="#B2000000"
        BorderBrush="#44FFFFFF"
        BorderThickness="1"
        CornerRadius="8">
        <Border.Effect>
            <DropShadowEffect
                BlurRadius="15"
                Direction="270"
                Opacity="0.5"
                ShadowDepth="4" />
        </Border.Effect>

        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="35" />
                <RowDefinition Height="*" />
            </Grid.RowDefinitions>

            <Border
                Grid.Row="0"
                Background="#55000000"
                CornerRadius="7,7,0,0"
                Cursor="SizeAll"
                MouseLeftButtonDown="Header_MouseLeftButtonDown">

                <Border.ContextMenu>
                    <ContextMenu x:Name="HeaderContextMenu">
                        <MenuItem Header="Create New Fence" Click="Menu_NewFence_Click"/>

                        <MenuItem Header="View">
                            <MenuItem x:Name="MenuRollUpFence" Header="Roll-up Fence" Click="Menu_RollUp_Click"/>
                            <Separator/>
                            <MenuItem Header="Opacity">
                                <MenuItem Header="0% (Mouseover Reveal)" Tag="0.0" Click="Menu_Opacity_Click"/>
                                <MenuItem Header="20%" Tag="0.2" Click="Menu_Opacity_Click"/>
                                <MenuItem Header="40%" Tag="0.4" Click="Menu_Opacity_Click"/>
                                <MenuItem Header="60%" Tag="0.6" Click="Menu_Opacity_Click"/>
                                <MenuItem Header="80%" Tag="0.8" Click="Menu_Opacity_Click"/>
                                <MenuItem Header="100% (Fully Visible)" Tag="1.0" Click="Menu_Opacity_Click"/>
                            </MenuItem>
                            <Separator/>
                            <MenuItem Header="Copy Color" Click="Menu_CopyColor_Click"/>
                            <MenuItem Header="Edit Color..." Click="Menu_EditColor_Click"/>
                        </MenuItem>

                        <MenuItem Header="Sort by">
                            <MenuItem Header="None" Tag="None" Click="Menu_Sort_Click"/>
                            <Separator/>
                            <MenuItem Header="Name" Tag="Name" Click="Menu_Sort_Click"/>
                            <MenuItem Header="Size" Tag="Size" Click="Menu_Sort_Click"/>
                            <MenuItem Header="Item Type" Tag="Type" Click="Menu_Sort_Click"/>
                            <MenuItem Header="Date Modified" Tag="DateMod" Click="Menu_Sort_Click"/>
                            <MenuItem Header="Date Created" Tag="DateCre" Click="Menu_Sort_Click"/>
                            <MenuItem Header="Date added to Fence" Tag="DateAdd" Click="Menu_Sort_Click"/>
                        </MenuItem>

                        <Separator/>
                        <MenuItem Header="Settings (Classic Menu)..." Click="Menu_Settings_Click"/>
                        <MenuItem Header="Delete This Fence" Click="Menu_DeleteFence_Click" Foreground="Red"/>
                    </ContextMenu>
                </Border.ContextMenu>

                <Grid x:Name="HeaderGrid">
                    <TextBlock x:Name="MenuIcon" Text="☰" Foreground="White" FontSize="16" VerticalAlignment="Center" HorizontalAlignment="Left" Margin="10,0,0,0" Cursor="Hand" MouseLeftButtonDown="MenuIcon_MouseLeftButtonDown" Background="Transparent" Padding="5"/>
                    <TextBlock x:Name="TitleText" HorizontalAlignment="Center" VerticalAlignment="Center" FontFamily="Segoe UI Variable, Segoe UI" FontSize="14" FontWeight="SemiBold" Foreground="White" Text="My Apps" Cursor="IBeam" MouseLeftButtonDown="TitleText_MouseLeftButtonDown" Background="Transparent" Padding="15,0,15,0"/>
                </Grid>
            </Border>

            <Grid Grid.Row="1">
                <ScrollViewer VerticalScrollBarVisibility="Auto">
                    <WrapPanel
                        x:Name="IconPanel"
                        Margin="10"
                        Background="Transparent"
                        MouseLeftButtonDown="IconPanel_MouseLeftButtonDown"
                        MouseLeftButtonUp="IconPanel_MouseLeftButtonUp"
                        MouseMove="IconPanel_MouseMove"
                        Orientation="Horizontal">
                        <TextBlock
                            Margin="10"
                            HorizontalAlignment="Center"
                            VerticalAlignment="Center"
                            Foreground="#88FFFFFF"
                            Text="Drop shortcuts here..." />
                    </WrapPanel>
                </ScrollViewer>

                <Canvas x:Name="SelectionCanvas" IsHitTestVisible="False">
                    <Rectangle
                        x:Name="SelectionBox"
                        Fill="#550078D7"
                        Stroke="#0078D7"
                        StrokeThickness="1"
                        Visibility="Collapsed" />
                </Canvas>
            </Grid>

            <Thumb Grid.RowSpan="2" Width="6" HorizontalAlignment="Left" Background="Transparent" Cursor="SizeWE" DragCompleted="Resize_DragCompleted" DragDelta="ResizeLeft_DragDelta" />
            <Thumb Grid.RowSpan="2" Width="6" HorizontalAlignment="Right" Background="Transparent" Cursor="SizeWE" DragCompleted="Resize_DragCompleted" DragDelta="ResizeRight_DragDelta" />
            <Thumb Grid.RowSpan="2" Height="6" VerticalAlignment="Top" Background="Transparent" Cursor="SizeNS" DragCompleted="Resize_DragCompleted" DragDelta="ResizeTop_DragDelta" />
            <Thumb Grid.RowSpan="2" Height="6" VerticalAlignment="Bottom" Background="Transparent" Cursor="SizeNS" DragCompleted="Resize_DragCompleted" DragDelta="ResizeBottom_DragDelta" />
            <Thumb Grid.RowSpan="2" Width="14" Height="14" HorizontalAlignment="Left" VerticalAlignment="Top" Background="Transparent" Cursor="SizeNWSE" DragCompleted="Resize_DragCompleted" DragDelta="ResizeTopLeft_DragDelta" />
            <Thumb Grid.RowSpan="2" Width="14" Height="14" HorizontalAlignment="Right" VerticalAlignment="Top" Background="Transparent" Cursor="SizeNESW" DragCompleted="Resize_DragCompleted" DragDelta="ResizeTopRight_DragDelta" />
            <Thumb Grid.RowSpan="2" Width="14" Height="14" HorizontalAlignment="Left" VerticalAlignment="Bottom" Background="Transparent" Cursor="SizeNESW" DragCompleted="Resize_DragCompleted" DragDelta="ResizeBottomLeft_DragDelta" />
            <Thumb Grid.RowSpan="2" Width="14" Height="14" HorizontalAlignment="Right" VerticalAlignment="Bottom" Background="Transparent" Cursor="SizeNWSE" DragCompleted="Resize_DragCompleted" DragDelta="ResizeBottomRight_DragDelta" />
        </Grid>
    </Border>
</Window>