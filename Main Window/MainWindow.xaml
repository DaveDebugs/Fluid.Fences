<Window
    x:Class="DesktopFences.MainWindow"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    Title="Fluid Fence"
    Width="250"
    Height="300"
    AllowsTransparency="True"
    Background="Transparent"
    FontFamily="Segoe UI Variable, Segoe UI, Arial"
    Loaded="Window_Loaded"
    ShowInTaskbar="False"
    Topmost="False"
    WindowStyle="None"
    AllowDrop="True"
    Drop="Window_Drop"
    DragEnter="Window_DragEnter"
    DragLeave="Window_DragLeave"
    DragOver="Window_DragOver"
    MouseEnter="Window_MouseEnter"
    MouseLeave="Window_MouseLeave"
    Deactivated="Window_Deactivated">

    <Window.Resources>
        <Style x:Key="FenceScrollThumb" TargetType="Thumb">
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Thumb">
                        <Border x:Name="ThumbBorder" Background="#44FFFFFF" CornerRadius="4" Margin="2,0,2,0"/>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="ThumbBorder" Property="Background" Value="#88FFFFFF"/>
                            </Trigger>
                            <Trigger Property="IsDragging" Value="True">
                                <Setter TargetName="ThumbBorder" Property="Background" Value="#BBFFFFFF"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style TargetType="ScrollBar">
            <Setter Property="Width" Value="10" />
            <Setter Property="Background" Value="Transparent" />
            <Setter Property="BorderThickness" Value="0" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ScrollBar">
                        <Grid Background="Transparent">
                            <Track x:Name="PART_Track" IsDirectionReversed="true">
                                <Track.DecreaseRepeatButton>
                                    <RepeatButton Command="{x:Static ScrollBar.PageUpCommand}" Opacity="0" Focusable="False" />
                                </Track.DecreaseRepeatButton>
                                <Track.Thumb>
                                    <Thumb Style="{StaticResource FenceScrollThumb}" />
                                </Track.Thumb>
                                <Track.IncreaseRepeatButton>
                                    <RepeatButton Command="{x:Static ScrollBar.PageDownCommand}" Opacity="0" Focusable="False" />
                                </Track.IncreaseRepeatButton>
                            </Track>
                        </Grid>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Window.Resources>

    <Border
        x:Name="MainBorder"
        Background="#01000000"
        Style="{DynamicResource ActiveFenceBorderStyle}">

        <Grid x:Name="MainGrid" Background="Transparent">
            <Grid.RowDefinitions>
                <RowDefinition x:Name="HeaderRowTop" Height="35" />
                <RowDefinition Height="*" />
                <RowDefinition x:Name="HeaderRowBottom" Height="0" />
            </Grid.RowDefinitions>
            <Grid.ColumnDefinitions>
                <ColumnDefinition x:Name="HeaderColLeft" Width="0" />
                <ColumnDefinition Width="*" />
                <ColumnDefinition x:Name="HeaderColRight" Width="0" />
            </Grid.ColumnDefinitions>

            <Border
                x:Name="HeaderBorder"
                Grid.Row="0"
                Grid.Column="0"
                Grid.ColumnSpan="3"
                Background="{DynamicResource ThemeHeaderBrush}"
                CornerRadius="8,8,0,0"
                Cursor="Hand"
                MouseLeftButtonDown="Header_MouseLeftButtonDown"
                MouseLeftButtonUp="Header_MouseLeftButtonUp"
                MouseMove="Header_MouseMove">

                <Border.ContextMenu>
                    <ContextMenu x:Name="HeaderContextMenu">
                        <MenuItem x:Name="MenuNewFence" Click="Menu_NewFence_Click" Header="Create New Fence" />
                        <MenuItem x:Name="MenuNewPortal" Click="Menu_NewPortal_Click" Header="Create Folder Portal..." />
                        <Separator />
                        <MenuItem x:Name="MenuRollUpFence" Click="Menu_RollUp_Click" Header="Roll-up Fence" />
                        <MenuItem Header="View">
                            <MenuItem Click="Menu_IconSize_Click" Header="Small Icons" Tag="32" />
                            <MenuItem Click="Menu_IconSize_Click" Header="Medium Icons" Tag="48" />
                            <MenuItem Click="Menu_IconSize_Click" Header="Large Icons" Tag="64" />
                        </MenuItem>
                        <MenuItem Header="Sort by">
                            <MenuItem Click="Menu_Sort_Click" Header="None (Custom)" Tag="None" />
                            <MenuItem Click="Menu_Sort_Click" Header="Name" Tag="Name" />
                            <MenuItem Click="Menu_Sort_Click" Header="Size" Tag="Size" />
                            <MenuItem Click="Menu_Sort_Click" Header="Item Type" Tag="Type" />
                            <MenuItem Click="Menu_Sort_Click" Header="Date Modified" Tag="DateMod" />
                            <MenuItem Click="Menu_Sort_Click" Header="Date Created" Tag="DateCre" />
                        </MenuItem>
                        <Separator />
                        <MenuItem x:Name="MenuEditColor" Click="Menu_EditColor_Click" Header="Edit Color..." />
                        <MenuItem x:Name="MenuSettings" Click="Menu_Settings_Click" Header="Settings..." />
                        <Separator />
                        <MenuItem x:Name="MenuDeleteFence" Click="Menu_DeleteFence_Click" Header="Delete Fence" Foreground="#FF4444" />
                    </ContextMenu>
                </Border.ContextMenu>

                <Grid x:Name="HeaderGrid">
                    <StackPanel
                        x:Name="TitleStack"
                        Margin="15,0"
                        HorizontalAlignment="Left"
                        VerticalAlignment="Center"
                        Orientation="Horizontal">

                        <TextBlock
                            x:Name="TitleText"
                            Text="Fluid Fence"
                            Style="{DynamicResource ActiveTitleStyle}"
                            MouseLeftButtonDown="TitleText_MouseLeftButtonDown" />
                    </StackPanel>

                    <StackPanel
                        HorizontalAlignment="Right"
                        VerticalAlignment="Center"
                        Orientation="Horizontal">

                        <Border
                            x:Name="SearchIcon"
                            Background="Transparent"
                            Cursor="Hand"
                            Padding="12,10"
                            Margin="0,0,2,0"
                            MouseLeftButtonDown="SearchIcon_MouseLeftButtonDown">
                            <Path
                                Width="14"
                                Height="14"
                                Data="M 15.5 14 L 10.71 9.21 C 11.52 8.08 12 6.6 12 5 C 12 2.24 9.76 0 7 0 C 4.24 0 2 2.24 2 5 C 2 7.76 4.24 10 7 10 C 8.6 10 10.08 9.52 11.21 8.71 L 16 13.5 L 15.5 14 Z M 7 8 C 5.34 8 4 6.66 4 5 C 4 3.34 5.34 2 7 2 C 8.66 2 10 3.34 10 5 C 10 6.66 8.66 8 7 8 Z"
                                Fill="#CCCCCC"
                                Stretch="Uniform" />
                        </Border>

                        <Border
                            x:Name="MenuIcon"
                            Background="Transparent"
                            Cursor="Hand"
                            Padding="12,10"
                            Margin="0,0,4,0"
                            MouseLeftButtonDown="MenuIcon_MouseLeftButtonDown">
                            <Path
                                Width="16"
                                Height="16"
                                Data="M 2 4 h 12 v 2 H 2 Z m 0 5 h 12 v 2 H 2 Z m 0 5 h 12 v 2 H 2 Z"
                                Fill="#CCCCCC"
                                Stretch="Uniform" />
                        </Border>
                    </StackPanel>
                </Grid>
            </Border>

            <TextBox
                x:Name="SearchBox"
                Grid.Row="0"
                Grid.Column="0"
                Grid.ColumnSpan="3"
                Width="160"
                Height="26"
                Margin="0,4,35,0"
                HorizontalAlignment="Right"
                VerticalAlignment="Top"
                Background="#33000000"
                BorderBrush="#555"
                BorderThickness="1"
                Foreground="White"
                Padding="5,2"
                Visibility="Collapsed"
                Panel.ZIndex="999"
                TextChanged="SearchBox_TextChanged"
                LostFocus="SearchBox_LostFocus" />

            <ScrollViewer
                Grid.Row="1"
                Grid.Column="1"
                HorizontalScrollBarVisibility="Disabled"
                VerticalScrollBarVisibility="Auto">
                <Grid>
                    <Canvas x:Name="SelectionCanvas">
                        <Border
                            x:Name="SelectionBox"
                            Background="#330078D7"
                            BorderBrush="#0078D7"
                            BorderThickness="1"
                            Visibility="Collapsed" />
                    </Canvas>
                    <WrapPanel
                        x:Name="IconPanel"
                        Margin="5"
                        Background="Transparent"
                        MouseLeftButtonDown="IconPanel_MouseLeftButtonDown"
                        MouseLeftButtonUp="IconPanel_MouseLeftButtonUp"
                        MouseMove="IconPanel_MouseMove" />
                </Grid>
            </ScrollViewer>

            <Rectangle Grid.Row="0" Grid.RowSpan="3" Grid.Column="0" Grid.ColumnSpan="3" Width="4" HorizontalAlignment="Left" Cursor="SizeWE" Fill="Transparent" MouseLeftButtonDown="Resize_Left" Panel.ZIndex="1000"/>
            <Rectangle Grid.Row="0" Grid.RowSpan="3" Grid.Column="0" Grid.ColumnSpan="3" Width="4" HorizontalAlignment="Right" Cursor="SizeWE" Fill="Transparent" MouseLeftButtonDown="Resize_Right" Panel.ZIndex="1000"/>
            <Rectangle Grid.Row="0" Grid.RowSpan="3" Grid.Column="0" Grid.ColumnSpan="3" Height="4" VerticalAlignment="Top" Cursor="SizeNS" Fill="Transparent" MouseLeftButtonDown="Resize_Top" Panel.ZIndex="1000"/>
            <Rectangle Grid.Row="0" Grid.RowSpan="3" Grid.Column="0" Grid.ColumnSpan="3" Height="4" VerticalAlignment="Bottom" Cursor="SizeNS" Fill="Transparent" MouseLeftButtonDown="Resize_Bottom" Panel.ZIndex="1000"/>

            <Rectangle Grid.Row="0" Grid.RowSpan="3" Grid.Column="0" Grid.ColumnSpan="3" Width="6" Height="6" HorizontalAlignment="Left" VerticalAlignment="Top" Cursor="SizeNWSE" Fill="Transparent" MouseLeftButtonDown="Resize_TopLeft" Panel.ZIndex="1001"/>
            <Rectangle Grid.Row="0" Grid.RowSpan="3" Grid.Column="0" Grid.ColumnSpan="3" Width="6" Height="6" HorizontalAlignment="Right" VerticalAlignment="Top" Cursor="SizeNESW" Fill="Transparent" MouseLeftButtonDown="Resize_TopRight" Panel.ZIndex="1001"/>
            <Rectangle Grid.Row="0" Grid.RowSpan="3" Grid.Column="0" Grid.ColumnSpan="3" Width="6" Height="6" HorizontalAlignment="Left" VerticalAlignment="Bottom" Cursor="SizeNESW" Fill="Transparent" MouseLeftButtonDown="Resize_BottomLeft" Panel.ZIndex="1001"/>
            <Rectangle Grid.Row="0" Grid.RowSpan="3" Grid.Column="0" Grid.ColumnSpan="3" Width="6" Height="6" HorizontalAlignment="Right" VerticalAlignment="Bottom" Cursor="SizeNWSE" Fill="Transparent" MouseLeftButtonDown="Resize_BottomRight" Panel.ZIndex="1001"/>
        </Grid>
    </Border>
</Window>