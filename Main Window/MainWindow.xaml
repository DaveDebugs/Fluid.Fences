<Window
    x:Class="DesktopFences.MainWindow"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    Title="Fluid Fence"
    Width="250"
    Height="300"
    AllowDrop="True"
    AllowsTransparency="True"
    Background="Transparent"
    Deactivated="Window_Deactivated"
    DragEnter="Window_DragEnter"
    DragLeave="Window_DragLeave"
    DragOver="Window_DragOver"
    Drop="Window_Drop"
    FontFamily="Segoe UI Variable, Segoe UI, Arial"
    Loaded="Window_Loaded"
    MouseEnter="Window_MouseEnter"
    MouseLeave="Window_MouseLeave"
    ShowInTaskbar="False"
    Topmost="False"
    WindowStyle="None">

    <Window.Resources>
        <Style x:Key="FenceScrollThumb" TargetType="Thumb">
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Thumb">
                        <Border
                            x:Name="ThumbBorder"
                            Margin="2,0,2,0"
                            Background="#44FFFFFF"
                            CornerRadius="4" />
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="ThumbBorder" Property="Background" Value="#88FFFFFF" />
                            </Trigger>
                            <Trigger Property="IsDragging" Value="True">
                                <Setter TargetName="ThumbBorder" Property="Background" Value="#BBFFFFFF" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style TargetType="ScrollBar">
            <Setter Property="Width" Value="10" />
            <Setter Property="Background" Value="Transparent" />
            <Setter Property="BorderThickness" Value="0" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ScrollBar">
                        <Grid Background="Transparent">
                            <Track x:Name="PART_Track" IsDirectionReversed="true">
                                <Track.DecreaseRepeatButton>
                                    <RepeatButton
                                        Command="{x:Static ScrollBar.PageUpCommand}"
                                        Focusable="False"
                                        Opacity="0" />
                                </Track.DecreaseRepeatButton>
                                <Track.Thumb>
                                    <Thumb Style="{StaticResource FenceScrollThumb}" />
                                </Track.Thumb>
                                <Track.IncreaseRepeatButton>
                                    <RepeatButton
                                        Command="{x:Static ScrollBar.PageDownCommand}"
                                        Focusable="False"
                                        Opacity="0" />
                                </Track.IncreaseRepeatButton>
                            </Track>
                        </Grid>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="TabListBoxItem" TargetType="ListBoxItem">
            <Setter Property="Background" Value="Transparent" />
            <Setter Property="Foreground" Value="#BBBBBB" />
            <Setter Property="Padding" Value="12,4" />
            <Setter Property="Margin" Value="0,0,4,0" />
            <Setter Property="Cursor" Value="Hand" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ListBoxItem">
                        <Border Background="{TemplateBinding Background}" CornerRadius="4">
                            <ContentPresenter
                                Margin="{TemplateBinding Padding}"
                                HorizontalAlignment="Center"
                                VerticalAlignment="Center" />
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="Background" Value="#22FFFFFF" />
                                <Setter Property="Foreground" Value="White" />
                            </Trigger>
                            <Trigger Property="IsSelected" Value="True">
                                <Setter Property="Background" Value="#44FFFFFF" />
                                <Setter Property="Foreground" Value="White" />
                                <Setter Property="FontWeight" Value="SemiBold" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style TargetType="ContextMenu">
            <Setter Property="Background" Value="#CC1A1A1A" />
            <Setter Property="Foreground" Value="White" />
            <Setter Property="BorderBrush" Value="#44FFFFFF" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="Padding" Value="4" />
            <Setter Property="HasDropShadow" Value="False" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ContextMenu">
                        <Border
                            Background="{TemplateBinding Background}"
                            BorderBrush="{TemplateBinding BorderBrush}"
                            BorderThickness="{TemplateBinding BorderThickness}"
                            CornerRadius="8">
                            <StackPanel
                                Margin="{TemplateBinding Padding}"
                                IsItemsHost="True"
                                KeyboardNavigation.DirectionalNavigation="Cycle" />
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style TargetType="MenuItem">
            <Setter Property="Foreground" Value="White" />
            <Setter Property="Background" Value="Transparent" />
            <Setter Property="Padding" Value="10,6,15,6" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="MenuItem">
                        <Border
                            x:Name="Bd"
                            Margin="4,1"
                            Background="{TemplateBinding Background}"
                            CornerRadius="4">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="25" />
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="15" />
                                </Grid.ColumnDefinitions>

                                <Path
                                    x:Name="CheckMark"
                                    Grid.Column="0"
                                    Margin="8,0,0,0"
                                    HorizontalAlignment="Left"
                                    VerticalAlignment="Center"
                                    Data="M 2.5 5 L 4.5 7 L 9.5 1.5 L 10.5 2.5 L 4.5 9 L 1.5 6 Z"
                                    Fill="White"
                                    Visibility="Collapsed" />

                                <ContentPresenter
                                    Grid.Column="1"
                                    Margin="{TemplateBinding Padding}"
                                    VerticalAlignment="Center"
                                    ContentSource="Header"
                                    RecognizesAccessKey="True" />

                                <Path
                                    x:Name="RightArrow"
                                    Grid.Column="2"
                                    Margin="0,0,6,0"
                                    HorizontalAlignment="Right"
                                    VerticalAlignment="Center"
                                    Data="M 0 0 L 4 4 L 0 8 Z"
                                    Fill="#BBBBBB"
                                    Visibility="Collapsed" />

                                <Popup
                                    x:Name="PART_Popup"
                                    AllowsTransparency="True"
                                    Focusable="False"
                                    HorizontalOffset="-4"
                                    IsOpen="{Binding IsSubmenuOpen, RelativeSource={RelativeSource TemplatedParent}}"
                                    Placement="Right"
                                    PopupAnimation="Fade"
                                    VerticalOffset="-4">
                                    <Border
                                        Margin="0,0,8,8"
                                        Background="#E61A1A1A"
                                        BorderBrush="#44FFFFFF"
                                        BorderThickness="1"
                                        CornerRadius="8">
                                        <Border.Effect>
                                            <DropShadowEffect
                                                BlurRadius="5"
                                                Direction="315"
                                                Opacity="0.5"
                                                ShadowDepth="2"
                                                Color="Black" />
                                        </Border.Effect>
                                        <ScrollViewer CanContentScroll="True">
                                            <StackPanel
                                                Margin="2"
                                                IsItemsHost="True"
                                                KeyboardNavigation.DirectionalNavigation="Cycle" />
                                        </ScrollViewer>
                                    </Border>
                                </Popup>
                            </Grid>
                        </Border>

                        <ControlTemplate.Triggers>
                            <Trigger Property="IsHighlighted" Value="True">
                                <Setter TargetName="Bd" Property="Background" Value="#33FFFFFF" />
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter Property="Foreground" Value="#888888" />
                                <Setter TargetName="CheckMark" Property="Fill" Value="#888888" />
                            </Trigger>
                            <Trigger Property="IsChecked" Value="True">
                                <Setter TargetName="CheckMark" Property="Visibility" Value="Visible" />
                            </Trigger>
                            <Trigger Property="Role" Value="SubmenuHeader">
                                <Setter TargetName="RightArrow" Property="Visibility" Value="Visible" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style TargetType="Separator">
            <Setter Property="Background" Value="#33FFFFFF" />
            <Setter Property="Margin" Value="4,4" />
            <Setter Property="Height" Value="1" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Separator">
                        <Rectangle
                            Height="{TemplateBinding Height}"
                            Margin="{TemplateBinding Margin}"
                            Fill="{TemplateBinding Background}" />
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Window.Resources>

    <Border
        x:Name="MainBorder"
        Background="#01000000"
        CornerRadius="8">
        <Grid x:Name="MainGrid" Background="Transparent">
            <Grid.RowDefinitions>
                <RowDefinition x:Name="HeaderRowTop" Height="35" />
                <RowDefinition Height="*" />
                <RowDefinition x:Name="HeaderRowBottom" Height="0" />
            </Grid.RowDefinitions>
            <Grid.ColumnDefinitions>
                <ColumnDefinition x:Name="HeaderColLeft" Width="0" />
                <ColumnDefinition Width="*" />
                <ColumnDefinition x:Name="HeaderColRight" Width="0" />
            </Grid.ColumnDefinitions>

            <Border
                x:Name="HeaderBorder"
                Grid.Row="0"
                Grid.Column="0"
                Grid.ColumnSpan="3"
                Background="#22000000"
                CornerRadius="8,8,0,0"
                Cursor="Hand"
                MouseLeftButtonDown="Header_MouseLeftButtonDown"
                MouseLeftButtonUp="Header_MouseLeftButtonUp"
                MouseMove="Header_MouseMove">

                <Border.ContextMenu>
                    <ContextMenu x:Name="HeaderContextMenu">
                        <MenuItem Header="Create New...">
                            <MenuItem Click="Menu_NewFence_Click" Header="Empty Fence" />
                            <MenuItem Click="Menu_NewPortal_Click" Header="Folder Portal (Mirror PC Folder)" />
                            <Separator />
                            <MenuItem Click="Menu_NewTab_Click" Header="New Tab Inside This Fence" />
                        </MenuItem>

                        <MenuItem Click="Menu_AutoOrganize_Click" Header="Auto Organize (Pull from Desktop)" />
                        <Separator />

                        <MenuItem
                            x:Name="MenuRollUpFence"
                            Click="Menu_RollUp_Click"
                            Header="Roll-up Fence" />

                        <MenuItem Header="View">
                            <MenuItem Header="Icon Size">
                                <MenuItem
                                    Click="Menu_IconSize_Click"
                                    Header="Small"
                                    Tag="32" />
                                <MenuItem
                                    Click="Menu_IconSize_Click"
                                    Header="Medium"
                                    Tag="48" />
                                <MenuItem
                                    Click="Menu_IconSize_Click"
                                    Header="Large"
                                    Tag="64" />
                                <Separator />
                                <MenuItem
                                    Click="Menu_IconSize_Click"
                                    Header="Reset to Default"
                                    Tag="Default" />
                            </MenuItem>
                        </MenuItem>

                        <MenuItem Header="Sort by">
                            <MenuItem
                                Click="Menu_Sort_Click"
                                Header="None (Custom)"
                                Tag="None" />
                            <MenuItem
                                Click="Menu_Sort_Click"
                                Header="Name"
                                Tag="Name" />
                            <MenuItem
                                Click="Menu_Sort_Click"
                                Header="Size"
                                Tag="Size" />
                            <MenuItem
                                Click="Menu_Sort_Click"
                                Header="Item Type"
                                Tag="Type" />
                            <MenuItem
                                Click="Menu_Sort_Click"
                                Header="Date Modified"
                                Tag="DateMod" />
                            <MenuItem
                                Click="Menu_Sort_Click"
                                Header="Date Created"
                                Tag="DateCre" />
                        </MenuItem>

                        <Separator />
                        <MenuItem
                            x:Name="MenuEditColor"
                            Click="Menu_EditColor_Click"
                            Header="Edit Color..." />
                        <MenuItem
                            x:Name="MenuSettings"
                            Click="Menu_Settings_Click"
                            Header="Settings..." />
                        <Separator />
                        <MenuItem
                            x:Name="MenuDeleteFence"
                            Click="Menu_DeleteFence_Click"
                            Foreground="#FF4444"
                            Header="Delete Fence" />
                    </ContextMenu>
                </Border.ContextMenu>

                <Grid x:Name="HeaderGrid">
                    <StackPanel
                        x:Name="TitleStack"
                        Margin="15,0"
                        HorizontalAlignment="Left"
                        VerticalAlignment="Center"
                        Orientation="Horizontal">
                        <TextBlock
                            x:Name="TitleText"
                            FontWeight="SemiBold"
                            Foreground="White"
                            MouseLeftButtonDown="TitleText_MouseLeftButtonDown"
                            Text="Fluid Fence" />
                    </StackPanel>

                    <StackPanel
                        HorizontalAlignment="Right"
                        VerticalAlignment="Center"
                        Orientation="Horizontal">

                        <Border
                            x:Name="SearchIcon"
                            Margin="0,0,2,0"
                            Padding="12,10"
                            Background="Transparent"
                            Cursor="Hand"
                            MouseLeftButtonDown="SearchIcon_MouseLeftButtonDown">
                            <Path
                                Width="14"
                                Height="14"
                                Data="M 15.5 14 L 10.71 9.21 C 11.52 8.08 12 6.6 12 5 C 12 2.24 9.76 0 7 0 C 4.24 0 2 2.24 2 5 C 2 7.76 4.24 10 7 10 C 8.6 10 10.08 9.52 11.21 8.71 L 16 13.5 L 15.5 14 Z M 7 8 C 5.34 8 4 6.66 4 5 C 4 3.34 5.34 2 7 2 C 8.66 2 10 3.34 10 5 C 10 6.66 8.66 8 7 8 Z"
                                Fill="#CCCCCC"
                                Stretch="Uniform" />
                        </Border>

                        <Border
                            x:Name="MenuIcon"
                            Margin="0,0,4,0"
                            Padding="12,10"
                            Background="Transparent"
                            Cursor="Hand"
                            MouseLeftButtonDown="MenuIcon_MouseLeftButtonDown">
                            <Path
                                Width="16"
                                Height="16"
                                Data="M 2 4 h 12 v 2 H 2 Z m 0 5 h 12 v 2 H 2 Z m 0 5 h 12 v 2 H 2 Z"
                                Fill="#CCCCCC"
                                Stretch="Uniform" />
                        </Border>
                    </StackPanel>
                </Grid>
            </Border>

            <TextBox
                x:Name="SearchBox"
                Grid.Row="0"
                Grid.Column="0"
                Grid.ColumnSpan="3"
                Width="160"
                Height="26"
                Margin="0,4,35,0"
                Padding="5,2"
                HorizontalAlignment="Right"
                VerticalAlignment="Top"
                Panel.ZIndex="999"
                Background="#33000000"
                BorderBrush="#555"
                BorderThickness="1"
                Foreground="White"
                LostFocus="SearchBox_LostFocus"
                TextChanged="SearchBox_TextChanged"
                Visibility="Collapsed" />

            <Grid
                Grid.Row="1"
                Grid.Column="1"
                Margin="0,5,0,0">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="*" />
                </Grid.RowDefinitions>

                <Grid
                    x:Name="TabBarContainer"
                    Grid.Row="0"
                    Margin="10,0,10,5">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>

                    <ScrollViewer
                        VerticalAlignment="Center"
                        HorizontalScrollBarVisibility="Hidden"
                        VerticalScrollBarVisibility="Disabled">
                        <ListBox
                            x:Name="TabBar"
                            Background="Transparent"
                            BorderThickness="0"
                            ItemContainerStyle="{StaticResource TabListBoxItem}">
                            <ListBox.ItemsPanel>
                                <ItemsPanelTemplate>
                                    <StackPanel Orientation="Horizontal" />
                                </ItemsPanelTemplate>
                            </ListBox.ItemsPanel>
                        </ListBox>
                    </ScrollViewer>

                    <Button
                        x:Name="AddTabBtn"
                        Grid.Column="1"
                        Width="22"
                        Height="22"
                        Margin="4,0,0,0"
                        VerticalAlignment="Center"
                        Background="Transparent"
                        BorderThickness="0"
                        Click="AddTabBtn_Click"
                        Content="+"
                        Cursor="Hand"
                        FontSize="16"
                        Foreground="#BBBBBB">
                        <Button.Template>
                            <ControlTemplate TargetType="Button">
                                <Border Background="{TemplateBinding Background}" CornerRadius="4">
                                    <ContentPresenter
                                        Margin="0,-2,0,0"
                                        HorizontalAlignment="Center"
                                        VerticalAlignment="Center" />
                                </Border>
                                <ControlTemplate.Triggers>
                                    <Trigger Property="IsMouseOver" Value="True">
                                        <Setter Property="Background" Value="#22FFFFFF" />
                                        <Setter Property="Foreground" Value="White" />
                                    </Trigger>
                                </ControlTemplate.Triggers>
                            </ControlTemplate>
                        </Button.Template>
                    </Button>
                </Grid>

                <ScrollViewer
                    Grid.Row="1"
                    HorizontalScrollBarVisibility="Disabled"
                    VerticalScrollBarVisibility="Auto">
                    <Grid>
                        <Canvas x:Name="SelectionCanvas">
                            <Border
                                x:Name="SelectionBox"
                                Background="#330078D7"
                                BorderBrush="#0078D7"
                                BorderThickness="1"
                                Visibility="Collapsed" />
                        </Canvas>
                        <WrapPanel
                            x:Name="IconPanel"
                            Margin="5"
                            Background="Transparent"
                            MouseLeftButtonDown="IconPanel_MouseLeftButtonDown"
                            MouseLeftButtonUp="IconPanel_MouseLeftButtonUp"
                            MouseMove="IconPanel_MouseMove" />
                    </Grid>
                </ScrollViewer>
            </Grid>

            <Rectangle
                Grid.Row="0"
                Grid.RowSpan="3"
                Grid.Column="0"
                Grid.ColumnSpan="3"
                Width="4"
                HorizontalAlignment="Left"
                Panel.ZIndex="1000"
                Cursor="SizeWE"
                Fill="Transparent"
                MouseLeftButtonDown="Resize_Left" />
            <Rectangle
                Grid.Row="0"
                Grid.RowSpan="3"
                Grid.Column="0"
                Grid.ColumnSpan="3"
                Width="4"
                HorizontalAlignment="Right"
                Panel.ZIndex="1000"
                Cursor="SizeWE"
                Fill="Transparent"
                MouseLeftButtonDown="Resize_Right" />
            <Rectangle
                Grid.Row="0"
                Grid.RowSpan="3"
                Grid.Column="0"
                Grid.ColumnSpan="3"
                Height="4"
                VerticalAlignment="Top"
                Panel.ZIndex="1000"
                Cursor="SizeNS"
                Fill="Transparent"
                MouseLeftButtonDown="Resize_Top" />
            <Rectangle
                Grid.Row="0"
                Grid.RowSpan="3"
                Grid.Column="0"
                Grid.ColumnSpan="3"
                Height="4"
                VerticalAlignment="Bottom"
                Panel.ZIndex="1000"
                Cursor="SizeNS"
                Fill="Transparent"
                MouseLeftButtonDown="Resize_Bottom" />

            <Rectangle
                Grid.Row="0"
                Grid.RowSpan="3"
                Grid.Column="0"
                Grid.ColumnSpan="3"
                Width="6"
                Height="6"
                HorizontalAlignment="Left"
                VerticalAlignment="Top"
                Panel.ZIndex="1001"
                Cursor="SizeNWSE"
                Fill="Transparent"
                MouseLeftButtonDown="Resize_TopLeft" />
            <Rectangle
                Grid.Row="0"
                Grid.RowSpan="3"
                Grid.Column="0"
                Grid.ColumnSpan="3"
                Width="6"
                Height="6"
                HorizontalAlignment="Right"
                VerticalAlignment="Top"
                Panel.ZIndex="1001"
                Cursor="SizeNESW"
                Fill="Transparent"
                MouseLeftButtonDown="Resize_TopRight" />
            <Rectangle
                Grid.Row="0"
                Grid.RowSpan="3"
                Grid.Column="0"
                Grid.ColumnSpan="3"
                Width="6"
                Height="6"
                HorizontalAlignment="Left"
                VerticalAlignment="Bottom"
                Panel.ZIndex="1001"
                Cursor="SizeNESW"
                Fill="Transparent"
                MouseLeftButtonDown="Resize_BottomLeft" />
            <Rectangle
                Grid.Row="0"
                Grid.RowSpan="3"
                Grid.Column="0"
                Grid.ColumnSpan="3"
                Width="6"
                Height="6"
                HorizontalAlignment="Right"
                VerticalAlignment="Bottom"
                Panel.ZIndex="1001"
                Cursor="SizeNWSE"
                Fill="Transparent"
                MouseLeftButtonDown="Resize_BottomRight" />
        </Grid>
    </Border>
</Window>