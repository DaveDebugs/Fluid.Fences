<Window x:Class="DesktopFences.ColorPickerWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Edit Background Color" Height="550" Width="480" 
        WindowStartupLocation="CenterOwner" Background="#1E1E1E" Foreground="White"
        FontFamily="Segoe UI Variable Text, Segoe UI, Arial" 
        ResizeMode="NoResize" WindowStyle="ToolWindow">

    <Window.Resources>
        <Style x:Key="BlueSliderStyle" TargetType="Slider">
            <Setter Property="Margin" Value="10,0,0,0"/>
            <Setter Property="IsSnapToTickEnabled" Value="True"/>
            <Setter Property="TickFrequency" Value="1"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Slider">
                        <Grid>
                            <Border Height="4" CornerRadius="2" Background="{TemplateBinding Background}" VerticalAlignment="Center"/>
                            <Track x:Name="PART_Track">
                                <Track.Thumb>
                                    <Thumb Width="14" Height="22">
                                        <Thumb.Template>
                                            <ControlTemplate>
                                                <Path Data="M0,0 L14,0 L14,14 L7,22 L0,14 Z" Fill="#0078D7" />
                                            </ControlTemplate>
                                        </Thumb.Template>
                                    </Thumb>
                                </Track.Thumb>
                            </Track>
                        </Grid>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="WhiteSliderStyle" TargetType="Slider">
            <Setter Property="Margin" Value="10,0,0,0"/>
            <Setter Property="IsSnapToTickEnabled" Value="True"/>
            <Setter Property="TickFrequency" Value="1"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Slider">
                        <Grid>
                            <Border Height="4" CornerRadius="2" Background="{TemplateBinding Background}" VerticalAlignment="Center"/>
                            <Track x:Name="PART_Track">
                                <Track.Thumb>
                                    <Thumb Width="14" Height="22">
                                        <Thumb.Template>
                                            <ControlTemplate>
                                                <Path Data="M0,0 L14,0 L14,14 L7,22 L0,14 Z" Fill="#DDDDDD" />
                                            </ControlTemplate>
                                        </Thumb.Template>
                                    </Thumb>
                                </Track.Thumb>
                            </Track>
                        </Grid>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Window.Resources>

    <Grid Margin="20,15,20,20">
        <StackPanel>

            <TextBlock Text="Edit Background Color" FontSize="14" FontWeight="SemiBold" Margin="0,0,0,15"/>

            <Grid Margin="0,0,0,15">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <ComboBox Width="160" Background="#111" Foreground="White" BorderThickness="1" BorderBrush="#444" Padding="5" SelectionChanged="ComboBox_SelectionChanged">
                    <ComboBoxItem Content="Programs" IsSelected="True"/>
                    <ComboBoxItem Content="Folders"/>
                </ComboBox>

                <TextBlock Grid.Column="1" Text="Copy/paste/reset group style" Margin="15,0,0,0" VerticalAlignment="Center" Foreground="#999" FontSize="12" Cursor="Hand"/>

                <TextBlock Grid.Column="2" Text="🖋" Foreground="White" FontSize="18" VerticalAlignment="Center" Cursor="Hand" ToolTip="Pick a color from screen" RenderTransformOrigin="0.5,0.5">
                    <TextBlock.RenderTransform>
                        <RotateTransform Angle="135"/>
                    </TextBlock.RenderTransform>
                </TextBlock>
            </Grid>

            <CheckBox Content="Blend into wallpaper with Chameleon" Foreground="White" Margin="0,0,0,20"/>

            <Grid Margin="0,0,0,15">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="100"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>
                <TextBlock Text="Hue:" VerticalAlignment="Center" Foreground="#DDD"/>
                <Slider x:Name="HueSlider" Grid.Column="1" Style="{StaticResource BlueSliderStyle}" Minimum="0" Maximum="360" ValueChanged="Slider_ValueChanged">
                    <Slider.Background>
                        <LinearGradientBrush EndPoint="1,0">
                            <GradientStop Color="Red" Offset="0"/>
                            <GradientStop Color="Yellow" Offset="0.16"/>
                            <GradientStop Color="Lime" Offset="0.33"/>
                            <GradientStop Color="Cyan" Offset="0.5"/>
                            <GradientStop Color="Blue" Offset="0.66"/>
                            <GradientStop Color="Magenta" Offset="0.83"/>
                            <GradientStop Color="Red" Offset="1"/>
                        </LinearGradientBrush>
                    </Slider.Background>
                </Slider>
            </Grid>

            <Grid Margin="0,0,0,15">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="100"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>
                <TextBlock Text="Brightness:" VerticalAlignment="Center" Foreground="#DDD"/>
                <Slider x:Name="LightnessSlider" Grid.Column="1" Style="{StaticResource BlueSliderStyle}" Minimum="0" Maximum="100" Value="50" ValueChanged="Slider_ValueChanged">
                    <Slider.Background>
                        <LinearGradientBrush EndPoint="1,0">
                            <GradientStop Color="Black" Offset="0"/>
                            <GradientStop x:Name="BrightnessEndColor" Color="#00A2FF" Offset="1"/>
                        </LinearGradientBrush>
                    </Slider.Background>
                </Slider>
            </Grid>

            <Grid Margin="0,0,0,15">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="100"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>
                <TextBlock Text="Saturation:" VerticalAlignment="Center" Foreground="#DDD"/>
                <Slider x:Name="SaturationSlider" Grid.Column="1" Style="{StaticResource BlueSliderStyle}" Minimum="0" Maximum="100" Value="100" ValueChanged="Slider_ValueChanged">
                    <Slider.Background>
                        <LinearGradientBrush EndPoint="1,0">
                            <GradientStop Color="White" Offset="0"/>
                            <GradientStop x:Name="SaturationEndColor" Color="#00A2FF" Offset="1"/>
                        </LinearGradientBrush>
                    </Slider.Background>
                </Slider>
            </Grid>

            <Grid Margin="0,0,0,15">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="100"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>
                <TextBlock Text="Transparency:" VerticalAlignment="Center" Foreground="#DDD"/>
                <Slider x:Name="AlphaSlider" Grid.Column="1" Style="{StaticResource BlueSliderStyle}" Minimum="0" Maximum="100" Value="70" ValueChanged="Slider_ValueChanged">
                    <Slider.Background>
                        <LinearGradientBrush EndPoint="1,0">
                            <GradientStop Color="#00000000" Offset="0"/>
                            <GradientStop x:Name="AlphaEndColor" Color="#00A2FF" Offset="1"/>
                        </LinearGradientBrush>
                    </Slider.Background>
                </Slider>
            </Grid>

            <TextBlock Text="More options" Foreground="#888" FontSize="12" Cursor="Hand" Margin="0,5,0,25"/>


            <TextBlock Text="Edit Icon Tint" FontSize="14" FontWeight="SemiBold" Margin="0,0,0,10"/>

            <Border Background="#252525" CornerRadius="6" Padding="15">
                <StackPanel>

                    <Grid Margin="0,0,0,20">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>

                        <ComboBox Width="200" Background="#111" Foreground="White" BorderThickness="1" BorderBrush="#444" Padding="5">
                            <ComboBoxItem Content="Use Fence background color" IsSelected="True"/>
                            <ComboBoxItem Content="Custom Color"/>
                        </ComboBox>

                        <TextBlock Grid.Column="2" Text="🖋" Foreground="#888" FontSize="18" VerticalAlignment="Center" Cursor="Hand" ToolTip="Pick a color from screen" RenderTransformOrigin="0.5,0.5">
                            <TextBlock.RenderTransform>
                                <RotateTransform Angle="135"/>
                            </TextBlock.RenderTransform>
                        </TextBlock>
                    </Grid>

                    <Grid Margin="0,0,0,15" Opacity="0.5">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="90"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <TextBlock Text="Hue:" VerticalAlignment="Center" Foreground="#CCC"/>
                        <Slider x:Name="TintHueSlider" Grid.Column="1" Style="{StaticResource WhiteSliderStyle}" Minimum="0" Maximum="360" IsEnabled="False">
                            <Slider.Background>
                                <LinearGradientBrush EndPoint="1,0">
                                    <GradientStop Color="#550000" Offset="0"/>
                                    <GradientStop Color="#555500" Offset="0.16"/>
                                    <GradientStop Color="#005500" Offset="0.33"/>
                                    <GradientStop Color="#005555" Offset="0.5"/>
                                    <GradientStop Color="#000055" Offset="0.66"/>
                                    <GradientStop Color="#550055" Offset="0.83"/>
                                    <GradientStop Color="#550000" Offset="1"/>
                                </LinearGradientBrush>
                            </Slider.Background>
                        </Slider>
                    </Grid>

                    <Grid Margin="0,0,0,15" Opacity="0.5">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="90"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <TextBlock Text="Brightness:" VerticalAlignment="Center" Foreground="#CCC"/>
                        <Slider x:Name="TintLightnessSlider" Grid.Column="1" Style="{StaticResource WhiteSliderStyle}" Minimum="0" Maximum="100" Value="50" IsEnabled="False">
                            <Slider.Background>
                                <LinearGradientBrush EndPoint="1,0">
                                    <GradientStop Color="#111" Offset="0"/>
                                    <GradientStop Color="#555" Offset="1"/>
                                </LinearGradientBrush>
                            </Slider.Background>
                        </Slider>
                    </Grid>

                    <Grid Margin="0,0,0,0" Opacity="0.5">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="90"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <TextBlock Text="Saturation:" VerticalAlignment="Center" Foreground="#CCC"/>
                        <Slider x:Name="TintSaturationSlider" Grid.Column="1" Style="{StaticResource WhiteSliderStyle}" Minimum="0" Maximum="100" Value="50" IsEnabled="False">
                            <Slider.Background>
                                <LinearGradientBrush EndPoint="1,0">
                                    <GradientStop Color="#444" Offset="0"/>
                                    <GradientStop Color="#644" Offset="1"/>
                                </LinearGradientBrush>
                            </Slider.Background>
                        </Slider>
                    </Grid>

                </StackPanel>
            </Border>

            <Grid Margin="0,15,0,0">
                <Border x:Name="ColorPreview" Width="40" Height="25" CornerRadius="4" HorizontalAlignment="Left" BorderBrush="#555" BorderThickness="1"/>
                <Button Content="Apply" Width="80" Height="28" Foreground="White" HorizontalAlignment="Right" Cursor="Hand" Click="ApplyButton_Click">
                    <Button.Template>
                        <ControlTemplate TargetType="Button">
                            <Border x:Name="BtnBorder" Background="#0078D7" CornerRadius="4">
                                <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                            </Border>
                            <ControlTemplate.Triggers>
                                <Trigger Property="IsMouseOver" Value="True">
                                    <Setter TargetName="BtnBorder" Property="Background" Value="#005A9E"/>
                                </Trigger>
                            </ControlTemplate.Triggers>
                        </ControlTemplate>
                    </Button.Template>
                </Button>
            </Grid>

        </StackPanel>
    </Grid>
</Window>