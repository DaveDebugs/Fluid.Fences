<Window
    x:Class="DesktopFences.ColorPickerWindow"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    Title="Edit Background Color"
    Width="420"
    Height="380"
    Background="#2B2B2B"
    Foreground="White"
    ResizeMode="NoResize"
    WindowStartupLocation="CenterOwner">

    <Window.Resources>
        <Style TargetType="Slider">
            <Setter Property="IsMoveToPointEnabled" Value="True" />
            <Setter Property="Margin" Value="0,5,0,15" />
        </Style>
        <Style TargetType="TextBlock">
            <Setter Property="FontSize" Value="12" />
            <Setter Property="Foreground" Value="#CCCCCC" />
        </Style>
    </Window.Resources>

    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <Border
            x:Name="ColorPreview"
            Grid.Row="0"
            Height="60"
            Margin="0,0,0,20"
            BorderBrush="#444"
            BorderThickness="1"
            CornerRadius="8">
            <Border.Background>
                <DrawingBrush
                    TileMode="Tile"
                    Viewport="0,0,16,16"
                    ViewportUnits="Absolute">
                    <DrawingBrush.Drawing>
                        <DrawingGroup>
                            <GeometryDrawing Brush="#333333">
                                <GeometryDrawing.Geometry>
                                    <RectangleGeometry Rect="0,0,16,16" />
                                </GeometryDrawing.Geometry>
                            </GeometryDrawing>
                            <GeometryDrawing Brush="#444444">
                                <GeometryDrawing.Geometry>
                                    <GeometryGroup>
                                        <RectangleGeometry Rect="0,0,8,8" />
                                        <RectangleGeometry Rect="8,8,8,8" />
                                    </GeometryGroup>
                                </GeometryDrawing.Geometry>
                            </GeometryDrawing>
                        </DrawingGroup>
                    </DrawingBrush.Drawing>
                </DrawingBrush>
            </Border.Background>
            <Border x:Name="ColorOverlay" CornerRadius="7" />
        </Border>

        <Grid Grid.Row="1">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="100" />
                <ColumnDefinition Width="*" />
            </Grid.ColumnDefinitions>
            <TextBlock VerticalAlignment="Center" Text="Hue:" />
            <Border
                Grid.Column="1"
                Height="6"
                Margin="0,0,0,10"
                CornerRadius="3">
                <Border.Background>
                    <LinearGradientBrush StartPoint="0,0" EndPoint="1,0">
                        <GradientStop Offset="0.0" Color="#FF0000" />
                        <GradientStop Offset="0.16" Color="#FFFF00" />
                        <GradientStop Offset="0.33" Color="#00FF00" />
                        <GradientStop Offset="0.50" Color="#00FFFF" />
                        <GradientStop Offset="0.66" Color="#0000FF" />
                        <GradientStop Offset="0.83" Color="#FF00FF" />
                        <GradientStop Offset="1.0" Color="#FF0000" />
                    </LinearGradientBrush>
                </Border.Background>
            </Border>
            <Slider
                x:Name="HueSlider"
                Grid.Column="1"
                Background="Transparent"
                Maximum="360"
                Minimum="0"
                ValueChanged="Sliders_ValueChanged" />
        </Grid>

        <Grid Grid.Row="2">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="100" />
                <ColumnDefinition Width="*" />
            </Grid.ColumnDefinitions>
            <TextBlock VerticalAlignment="Center" Text="Brightness:" />
            <Slider
                x:Name="BrightnessSlider"
                Grid.Column="1"
                LargeChange="0.1"
                Maximum="1"
                Minimum="0"
                SmallChange="0.01"
                ValueChanged="Sliders_ValueChanged"
                Value="0.5" />
        </Grid>

        <Grid Grid.Row="3">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="100" />
                <ColumnDefinition Width="*" />
            </Grid.ColumnDefinitions>
            <TextBlock VerticalAlignment="Center" Text="Saturation:" />
            <Slider
                x:Name="SaturationSlider"
                Grid.Column="1"
                LargeChange="0.1"
                Maximum="1"
                Minimum="0"
                SmallChange="0.01"
                ValueChanged="Sliders_ValueChanged"
                Value="1" />
        </Grid>

        <Grid Grid.Row="4">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="100" />
                <ColumnDefinition Width="*" />
            </Grid.ColumnDefinitions>
            <TextBlock VerticalAlignment="Center" Text="Transparency:" />
            <Slider
                x:Name="TransparencySlider"
                Grid.Column="1"
                LargeChange="0.1"
                Maximum="1"
                Minimum="0"
                SmallChange="0.01"
                ValueChanged="Sliders_ValueChanged"
                Value="0.7" />
        </Grid>

        <StackPanel
            Grid.Row="5"
            HorizontalAlignment="Right"
            VerticalAlignment="Bottom"
            Orientation="Horizontal">
            <Button
                Width="80"
                Height="30"
                Margin="0,0,10,0"
                Background="#444"
                BorderThickness="0"
                Click="Cancel_Click"
                Content="Cancel"
                Cursor="Hand"
                Foreground="White" />
            <Button
                Width="80"
                Height="30"
                Background="#0078D7"
                BorderThickness="0"
                Click="Apply_Click"
                Content="Save Color"
                Cursor="Hand"
                Foreground="White" />
        </StackPanel>
    </Grid>
</Window>