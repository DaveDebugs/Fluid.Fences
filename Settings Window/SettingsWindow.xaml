<ui:FluentWindow
    x:Class="DesktopFences.SettingsWindow"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:ui="http://schemas.lepo.co/wpfui/2022/xaml"
    xmlns:local="clr-namespace:DesktopFences"
    Title="Fluid Fences Settings"
    Width="1080"
    Height="760"
    MinWidth="880"
    MinHeight="600"
    FontFamily="{DynamicResource CustomFontFamily}"
    WindowStartupLocation="CenterScreen"
    Closing="Window_Closing"
    WindowBackdropType="Mica"
    ExtendsContentIntoTitleBar="True"
    WindowChrome.WindowChrome="{x:Null}">

    <Window.Resources>
        <local:HexToBrushConverter x:Key="HexToBrush" />
        <local:EmptyStringToCollapsedConverter x:Key="EmptyToCollapsed" />
        <local:InverseBooleanConverter x:Key="InverseBool" />

        <Thickness x:Key="RowGap">0,0,0,16</Thickness>
        <Thickness x:Key="SectionGap">0,28,0,12</Thickness>
        <Thickness x:Key="CardPad">16</Thickness>

        <Style x:Key="PageTitle" TargetType="TextBlock">
            <Setter Property="FontSize" Value="28" />
            <Setter Property="FontWeight" Value="SemiBold" />
            <Setter Property="Margin" Value="0,0,0,4" />
            <Setter Property="Foreground" Value="{DynamicResource TextFillColorPrimaryBrush}" />
        </Style>

        <Style x:Key="PageSubtitle" TargetType="TextBlock">
            <Setter Property="FontSize" Value="13" />
            <Setter Property="Margin" Value="0,0,0,24" />
            <Setter Property="TextWrapping" Value="Wrap" />
            <Setter Property="Foreground" Value="{DynamicResource TextFillColorSecondaryBrush}" />
        </Style>

        <Style x:Key="SectionHeader" TargetType="TextBlock">
            <Setter Property="FontSize" Value="15" />
            <Setter Property="FontWeight" Value="SemiBold" />
            <Setter Property="Margin" Value="{StaticResource SectionGap}" />
            <Setter Property="Foreground" Value="{DynamicResource TextFillColorPrimaryBrush}" />
        </Style>

        <Style x:Key="AccentButton" TargetType="Button">
            <Setter Property="Background" Value="{DynamicResource CustomAccentBrush}" />
            <Setter Property="Foreground" Value="{DynamicResource CustomTextOnAccentBrush}" />
            <Setter Property="BorderThickness" Value="0" />
            <Setter Property="Padding" Value="14,6" />
            <Setter Property="Cursor" Value="Hand" />
            <Setter Property="SnapsToDevicePixels" Value="True" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="Bg"
                                Background="{TemplateBinding Background}"
                                CornerRadius="{DynamicResource CustomCornerRadiusSmall}"
                                Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"
                                              TextElement.Foreground="{TemplateBinding Foreground}" />
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Bg" Property="Opacity" Value="0.88" />
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="Bg" Property="Opacity" Value="0.75" />
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter TargetName="Bg" Property="Opacity" Value="0.4" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <DrawingBrush x:Key="AlphaCheckerboard" TileMode="Tile" Viewport="0,0,6,6"
                      ViewportUnits="Absolute" Stretch="None">
            <DrawingBrush.Drawing>
                <DrawingGroup>
                    <GeometryDrawing Brush="#FF5A5A5A">
                        <GeometryDrawing.Geometry>
                            <RectangleGeometry Rect="0,0,8,8" />
                        </GeometryDrawing.Geometry>
                    </GeometryDrawing>
                    <GeometryDrawing Brush="#FF4C4C4C">
                        <GeometryDrawing.Geometry>
                            <GeometryGroup>
                                <RectangleGeometry Rect="0,0,4,4" />
                                <RectangleGeometry Rect="4,4,4,4" />
                            </GeometryGroup>
                        </GeometryDrawing.Geometry>
                    </GeometryDrawing>
                </DrawingGroup>
            </DrawingBrush.Drawing>
        </DrawingBrush>

        <Style x:Key="GradientSlider" TargetType="Slider">
            <Setter Property="Height" Value="22" />
            <Setter Property="IsMoveToPointEnabled" Value="True" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Slider">
                        <Grid VerticalAlignment="Center">

                            <Border x:Name="TrackBase" Height="8" CornerRadius="4"
                                    Background="{StaticResource AlphaCheckerboard}"
                                    SnapsToDevicePixels="True" />
                            <Border Height="8" CornerRadius="4"
                                    Background="{TemplateBinding Background}"
                                    SnapsToDevicePixels="True" />

                            <Border Height="8" CornerRadius="4" IsHitTestVisible="False"
                                    BorderThickness="1" Opacity="0.22"
                                    BorderBrush="{DynamicResource CustomBorderSubtleBrush}"
                                    SnapsToDevicePixels="True" />

                            <Track x:Name="PART_Track">
                                <Track.DecreaseRepeatButton>
                                    <RepeatButton Command="Slider.DecreaseLarge" Opacity="0" Focusable="False" />
                                </Track.DecreaseRepeatButton>
                                <Track.IncreaseRepeatButton>
                                    <RepeatButton Command="Slider.IncreaseLarge" Opacity="0" Focusable="False" />
                                </Track.IncreaseRepeatButton>
                                <Track.Thumb>
                                    <Thumb x:Name="SliderThumb" Width="14" Height="14">
                                        <Thumb.Template>
                                            <ControlTemplate TargetType="Thumb">
                                                <Grid>

                                                    <Ellipse Fill="White">
                                                        <Ellipse.Effect>
                                                            <DropShadowEffect BlurRadius="4" ShadowDepth="0"
                                                                              Opacity="0.45" Color="Black" />
                                                        </Ellipse.Effect>
                                                    </Ellipse>
                                                    <Ellipse Margin="4" Fill="{DynamicResource CustomAccentBrush}" />
                                                </Grid>
                                            </ControlTemplate>
                                        </Thumb.Template>
                                    </Thumb>
                                </Track.Thumb>
                            </Track>

                            <Border x:Name="FocusRing" CornerRadius="6" Height="12"
                                    BorderBrush="{DynamicResource CustomFocusRingBrush}"
                                    BorderThickness="2" Visibility="Collapsed" />
                        </Grid>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsKeyboardFocused" Value="True">
                                <Setter TargetName="FocusRing" Property="Visibility" Value="Visible" />
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter Property="Opacity" Value="0.5" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="FieldLabel" TargetType="TextBlock">
            <Setter Property="FontSize" Value="12" />
            <Setter Property="Margin" Value="0,0,0,6" />
            <Setter Property="Foreground" Value="{DynamicResource TextFillColorSecondaryBrush}" />
        </Style>

        <Style x:Key="SettingsRow" TargetType="Border">
            <Setter Property="Background" Value="{DynamicResource ControlFillColorDefaultBrush}" />
            <Setter Property="BorderBrush" Value="{DynamicResource ControlElevationBorderBrush}" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="CornerRadius" Value="6" />
            <Setter Property="Padding" Value="16,12" />
            <Setter Property="Margin" Value="0,0,0,8" />
            <Setter Property="SnapsToDevicePixels" Value="True" />
        </Style>

        <Style x:Key="NavButton" TargetType="ToggleButton">
            <Setter Property="Height" Value="38" />
            <Setter Property="Margin" Value="0,0,0,2" />
            <Setter Property="Padding" Value="12,0" />
            <Setter Property="HorizontalContentAlignment" Value="Left" />
            <Setter Property="Cursor" Value="Hand" />
            <Setter Property="Foreground" Value="{DynamicResource TextFillColorPrimaryBrush}" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ToggleButton">
                        <Grid>
                            <Border x:Name="Fill" CornerRadius="5" Background="Transparent" />

                            <Border x:Name="Marker" Width="3" Height="18" CornerRadius="2"
                                    HorizontalAlignment="Left" Margin="2,0,0,0"
                                    Background="{DynamicResource SystemAccentColorPrimaryBrush}"
                                    Visibility="Collapsed" />
                            <ContentPresenter Margin="{TemplateBinding Padding}"
                                              VerticalAlignment="Center"
                                              HorizontalAlignment="Left" />
                            <Border x:Name="FocusRing" CornerRadius="5" BorderThickness="2"
                                    BorderBrush="{DynamicResource CustomFocusRingBrush}"
                                    Visibility="Collapsed" />
                        </Grid>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Fill" Property="Background"
                                        Value="{DynamicResource ControlFillColorSecondaryBrush}" />
                            </Trigger>
                            <Trigger Property="IsChecked" Value="True">
                                <Setter TargetName="Fill" Property="Background"
                                        Value="{DynamicResource ControlFillColorDefaultBrush}" />
                                <Setter TargetName="Marker" Property="Visibility" Value="Visible" />
                                <Setter Property="FontWeight" Value="SemiBold" />
                            </Trigger>
                            <Trigger Property="IsKeyboardFocused" Value="True">
                                <Setter TargetName="FocusRing" Property="Visibility" Value="Visible" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="CardPanel" TargetType="Border">
            <Setter Property="Background" Value="{DynamicResource ControlFillColorDefaultBrush}" />
            <Setter Property="BorderBrush" Value="{DynamicResource ControlElevationBorderBrush}" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="CornerRadius" Value="8" />
            <Setter Property="Padding" Value="{StaticResource CardPad}" />
            <Setter Property="Margin" Value="{StaticResource RowGap}" />
        </Style>

        <DataTemplate x:Key="ThemeSwatchTemplate">
            <Border Width="152" Height="98" Margin="0,0,10,10"
                    CornerRadius="8" BorderThickness="2" SnapsToDevicePixels="True"
                    Background="{Binding Colors.Background, Converter={StaticResource HexToBrush}, ConverterParameter=#FF8A8A8A}"
                    BorderBrush="Transparent"
                    Cursor="Hand"
                    Tag="{Binding Id}"
                    MouseLeftButtonUp="ThemeSwatch_Click"
                    MouseRightButtonUp="ThemeSwatch_RightClick"
                    ToolTip="{Binding Description}"
                    AutomationProperties.Name="{Binding Name}">

                <Border.ContextMenu>
                    <ContextMenu x:Name="SwatchMenu" />
                </Border.ContextMenu>
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="26" />
                        <RowDefinition Height="*" />
                    </Grid.RowDefinitions>

                    <Border Grid.Row="0" CornerRadius="6,6,0,0"
                            Background="{Binding Colors.Header, Converter={StaticResource HexToBrush}, ConverterParameter=#FF8A8A8A}">
                        <TextBlock Text="{Binding Name}" Margin="8,0" VerticalAlignment="Center"
                                   FontSize="11" FontWeight="SemiBold" TextTrimming="CharacterEllipsis"
                                   Foreground="{Binding Colors.TextPrimary, Converter={StaticResource HexToBrush}}" />
                    </Border>

                    <StackPanel Grid.Row="1" Margin="8,6">
                        <TextBlock Text="Aa  label text" FontSize="10"
                                   Foreground="{Binding Colors.TextSecondary, Converter={StaticResource HexToBrush}}" />
                        <StackPanel Orientation="Horizontal" Margin="0,8,0,0">
                            <Border Width="26" Height="12" CornerRadius="3" Margin="0,0,4,0"
                                    Background="{Binding Colors.Accent, Converter={StaticResource HexToBrush}}" />
                            <Border Width="14" Height="12" CornerRadius="3" Margin="0,0,4,0"
                                    Background="{Binding Colors.Success, Converter={StaticResource HexToBrush}}" />
                            <Border Width="14" Height="12" CornerRadius="3"
                                    Background="{Binding Colors.Error, Converter={StaticResource HexToBrush}}" />
                        </StackPanel>
                        <TextBlock Text="{Binding Category}" FontSize="9" Margin="0,6,0,0" Opacity="0.7"
                                   Foreground="{Binding Colors.TextSecondary, Converter={StaticResource HexToBrush}}" />
                    </StackPanel>
                </Grid>
            </Border>
        </DataTemplate>
    </Window.Resources>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <ui:TitleBar Grid.Row="0" Title="Fluid Fences Settings" Icon="{ui:SymbolIcon Symbol=Settings24}" />

        <Grid Grid.Row="1">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="236" />
                <ColumnDefinition Width="*" />
            </Grid.ColumnDefinitions>

            <Grid Grid.Column="0" Margin="12,0,0,12">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="*" />
                    <RowDefinition Height="Auto" />
                </Grid.RowDefinitions>

                <ui:TextBox x:Name="SettingsSearch" AutomationProperties.Name="Search settings" Grid.Row="0" Margin="0,4,0,12"
                            PlaceholderText="Search settings"
                            Icon="{ui:SymbolIcon Symbol=Search24}"
                            TextChanged="SettingsSearch_TextChanged" />

                <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled"
                              AutomationProperties.Name="Settings navigation">
                    <StackPanel x:Name="NavList" />
                </ScrollViewer>

                <StackPanel Grid.Row="2">
                    <Border Height="1" Margin="0,8" Background="{DynamicResource ControlElevationBorderBrush}" />
                    <TextBlock x:Name="VersionText" FontSize="11" Margin="12,0,0,4" Opacity="0.6"
                               Foreground="{DynamicResource TextFillColorSecondaryBrush}" />
                </StackPanel>
            </Grid>

            <Border Grid.Column="1" Margin="12,0,12,12"
                    Background="{DynamicResource LayerFillColorDefaultBrush}"
                    BorderBrush="{DynamicResource ControlElevationBorderBrush}"
                    BorderThickness="1" CornerRadius="8">
                <ScrollViewer x:Name="PageScroller" VerticalScrollBarVisibility="Auto" Padding="28,24,28,24"
                              AutomationProperties.Name="Settings content">

                    <Grid x:Name="PageHost">
                        <Grid.RenderTransform>
                            <TranslateTransform />
                        </Grid.RenderTransform>

                        <StackPanel x:Name="AboutGrid">
                            <StackPanel Orientation="Horizontal" Margin="0,0,0,2">
                                <Border Width="54" Height="54" CornerRadius="13" ClipToBounds="True"
                                        Margin="0,0,16,0" VerticalAlignment="Center"
                                        Background="{DynamicResource ApplicationBackgroundBrush}">
                                    <MediaElement x:Name="HomeLogoAnim" Width="54" Height="54"
                                                  Stretch="UniformToFill" LoadedBehavior="Manual"
                                                  ScrubbingEnabled="False" IsMuted="True"
                                                  MediaEnded="HomeLogoAnim_Ended"/>
                                </Border>
                                <TextBlock Style="{StaticResource PageTitle}" Text="Fluid Fences" VerticalAlignment="Center" Margin="0"/>
                            </StackPanel>
                            <TextBlock x:Name="AboutDescriptionText" Style="{StaticResource PageSubtitle}"
                                       Text="An open-source way to tidy your desktop. Group shortcuts into translucent fences, mirror folders, and get your wallpaper back." />

                            <Border Style="{StaticResource CardPanel}">
                                <StackPanel>
                                    <TextBlock Text="At a glance" FontWeight="SemiBold" Margin="0,0,0,12" />
                                    <UniformGrid Columns="3">
                                        <StackPanel Margin="0,0,12,0">
                                            <TextBlock x:Name="StatFenceCount" FontSize="24" FontWeight="SemiBold" Text="0" />
                                            <TextBlock Text="fences" Style="{StaticResource FieldLabel}" />
                                        </StackPanel>
                                        <StackPanel Margin="0,0,12,0">
                                            <TextBlock x:Name="StatThemeCount" FontSize="24" FontWeight="SemiBold" Text="0" />
                                            <TextBlock Text="themes installed" Style="{StaticResource FieldLabel}" />
                                        </StackPanel>
                                        <StackPanel>
                                            <TextBlock x:Name="StatActiveTheme" FontSize="24" FontWeight="SemiBold" Text="-"
                                                       TextTrimming="CharacterEllipsis" />
                                            <TextBlock Text="active theme" Style="{StaticResource FieldLabel}" />
                                        </StackPanel>
                                    </UniformGrid>
                                </StackPanel>
                            </Border>

                            <TextBlock Style="{StaticResource SectionHeader}" Text="Support the project" />
                            <Border Style="{StaticResource CardPanel}">
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="3*" />
                                        <ColumnDefinition Width="*" />
                                    </Grid.ColumnDefinitions>
                                    <StackPanel Grid.Column="0" VerticalAlignment="Center" Margin="0,0,16,0">
                                        <TextBlock Text="Fluid Fences is free and open source." FontWeight="SemiBold" Margin="0,0,0,4" />
                                        <TextBlock Style="{StaticResource FieldLabel}" TextWrapping="Wrap"
                                                   Text="If it earned a place on your desktop, a coffee keeps it going." />

                                        <ui:Button Margin="0,10,0,0" HorizontalAlignment="Left" Padding="16,8"
                                                   Background="{DynamicResource CustomAccentBrush}"
                                                   Foreground="{DynamicResource CustomTextOnAccentBrush}"
                                                   BorderBrush="{DynamicResource CustomAccentBrush}"
                                                   Content="Buy me a coffee"
                                                   Icon="{ui:SymbolIcon Symbol=DrinkCoffee24}" Click="BuyMeACoffee_Click" />
                                    </StackPanel>

                                    <Button Grid.Column="1" Click="VenmoQr_Click"
                                            Cursor="Hand"
                                            HorizontalAlignment="Right" VerticalAlignment="Center"
                                            MinWidth="96" MaxWidth="240"
                                            Background="Transparent" BorderThickness="0" Padding="0"
                                            ToolTip="Open this Venmo link in your browser"
                                            AutomationProperties.Name="Donate via Venmo, opens the link in your browser">
                                        <Button.Template>
                                            <ControlTemplate TargetType="Button">
                                                <Border x:Name="Chrome" CornerRadius="6" Background="White" Padding="6"
                                                        BorderBrush="{DynamicResource CustomFocusRingBrush}"
                                                        BorderThickness="0">
                                                    <Viewbox Stretch="Uniform">
                                                        <Image Source="/Settings Window/BuyMeACoffeeQR.png"
                                                               RenderOptions.BitmapScalingMode="HighQuality" />
                                                    </Viewbox>
                                                </Border>
                                                <ControlTemplate.Triggers>
                                                    <Trigger Property="IsMouseOver" Value="True">
                                                        <Setter TargetName="Chrome" Property="Opacity" Value="0.85" />
                                                    </Trigger>
                                                    <Trigger Property="IsKeyboardFocused" Value="True">
                                                        <Setter TargetName="Chrome" Property="BorderThickness" Value="2" />
                                                    </Trigger>
                                                </ControlTemplate.Triggers>
                                            </ControlTemplate>
                                        </Button.Template>
                                    </Button>
                                </Grid>
                            </Border>
                        </StackPanel>

                        <StackPanel x:Name="GeneralGrid" Visibility="Collapsed">
                            <TextBlock Style="{StaticResource PageTitle}" Text="General" />
                            <TextBlock Style="{StaticResource PageSubtitle}"
                                       Text="Application-wide behaviour. Changes save as you make them." />

                            <Border Style="{StaticResource SettingsRow}">
                                <ui:ToggleSwitch x:Name="StartupToggle" Content="Start Fluid Fences with Windows" />
                            </Border>
                            <Border Style="{StaticResource SettingsRow}">
                                <ui:ToggleSwitch x:Name="TaskbarToggle" Content="Show fences in the Windows taskbar" />
                            </Border>
                            <Border Style="{StaticResource SettingsRow}">
                                <StackPanel>
                                    <ui:ToggleSwitch x:Name="RestoreFilesToggle" Content="Return files to the Desktop when a fence is deleted" />
                                    <TextBlock Style="{StaticResource FieldLabel}" Margin="0,6,0,0" TextWrapping="Wrap"
                                               Text="With this off, deleting a fence also removes the files it holds." />
                                </StackPanel>
                            </Border>
                            <Border Style="{StaticResource SettingsRow}">
                                <StackPanel>
                                    <ui:ToggleSwitch x:Name="GhostModeToggle" Content="Ghost Mode" />
                                    <TextBlock Style="{StaticResource FieldLabel}" Margin="0,6,0,0" TextWrapping="Wrap"
                                               Text="Fences fade out until you hover over them. Individual fences can override this." />
                                </StackPanel>
                            </Border>
                            <Border Style="{StaticResource SettingsRow}">
                                <ui:ToggleSwitch x:Name="PauseMediaToggle" Content="Pause background video while a fence is rolled up" />
                            </Border>

                            <TextBlock Style="{StaticResource SectionHeader}" Text="Layout snapshots" />
                            <Border Style="{StaticResource CardPanel}">
                                <StackPanel>
                                    <TextBlock Style="{StaticResource FieldLabel}" TextWrapping="Wrap"
                                               Text="Save where every fence sits so you can put them back after a display change. Useful when monitors come and go." />
                                    <StackPanel Orientation="Horizontal" Margin="0,12,0,0">

                                        <ui:Button Padding="16,8" Margin="0,0,10,0"
                                                   Background="{DynamicResource CustomAccentBrush}"
                                                   Foreground="{DynamicResource CustomTextOnAccentBrush}"
                                                   BorderBrush="{DynamicResource CustomAccentBrush}"
                                                   Content="Save current layout" Icon="{ui:SymbolIcon Symbol=Save24}"
                                                   Click="SaveLayout_Click" />
                                        <ui:Button Padding="16,8" Content="Restore last layout"
                                                   Icon="{ui:SymbolIcon Symbol=ArrowUndo24}" Click="RestoreLayout_Click" />
                                    </StackPanel>
                                </StackPanel>
                            </Border>
                        </StackPanel>

                        <Grid x:Name="FencesGrid" Visibility="Collapsed">
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="*" />
                            </Grid.RowDefinitions>

                            <StackPanel Grid.Row="0">
                                <TextBlock Style="{StaticResource PageTitle}" Text="Fences" />
                                <TextBlock Style="{StaticResource PageSubtitle}"
                                           Text="Everything about one fence in one place: name, sorting, appearance and background." />
                            </StackPanel>

                            <Grid Grid.Row="1">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="210" />
                                    <ColumnDefinition Width="*" />
                                </Grid.ColumnDefinitions>

                                <Border Grid.Column="0" Style="{StaticResource CardPanel}" Margin="0,0,16,0">
                                    <StackPanel>
                                        <TextBlock Text="Your fences" FontWeight="SemiBold" Margin="0,0,0,8" />
                                        <ui:ListView x:Name="FenceListBox" AutomationProperties.Name="Your fences" MinHeight="240" MaxHeight="420"
                                                     BorderThickness="0" Background="Transparent"
                                                     SelectionChanged="FenceListBox_SelectionChanged" />
                                        <TextBlock x:Name="NoFencesHint" Style="{StaticResource FieldLabel}"
                                                   Margin="0,8,0,0" TextWrapping="Wrap" Visibility="Collapsed"
                                                   Text="No fences yet. Right-click the tray icon to create one." />
                                    </StackPanel>
                                </Border>

                                <ScrollViewer Grid.Column="1" VerticalScrollBarVisibility="Auto"
                                              AutomationProperties.Name="Fence settings">
                                    <StackPanel x:Name="FenceDetailPanel">

                                        <Border Style="{StaticResource CardPanel}">
                                            <StackPanel>
                                                <TextBlock Text="Identity" FontWeight="SemiBold" Margin="0,0,0,12" />
                                                <TextBlock Style="{StaticResource FieldLabel}" Text="Fence name" />
                                                <ui:TextBox x:Name="TitleInput" AutomationProperties.Name="Fence title" Margin="0,0,0,16" />

                                                <Grid>
                                                    <Grid.ColumnDefinitions>
                                                        <ColumnDefinition Width="*" />
                                                        <ColumnDefinition Width="16" />
                                                        <ColumnDefinition Width="*" />
                                                    </Grid.ColumnDefinitions>
                                                    <StackPanel Grid.Column="0">
                                                        <TextBlock Style="{StaticResource FieldLabel}" Text="Sort items by" />

                                                        <ComboBox x:Name="SortDropdown" AutomationProperties.Name="Sort items by">
                                                            <ComboBoxItem Content="Custom (manual order)" Tag="Custom" />
                                                            <ComboBoxItem Content="None" Tag="None" />
                                                            <ComboBoxItem Content="Name" Tag="Name" />
                                                            <ComboBoxItem Content="Size" Tag="Size" />
                                                            <ComboBoxItem Content="Item Type" Tag="Type" />
                                                            <ComboBoxItem Content="Date Modified" Tag="DateMod" />
                                                            <ComboBoxItem Content="Date Created" Tag="DateCre" />
                                                            <ComboBoxItem Content="Date added to Fence" Tag="DateAdd" />
                                                        </ComboBox>
                                                    </StackPanel>
                                                    <StackPanel Grid.Column="2">
                                                        <TextBlock Style="{StaticResource FieldLabel}" Text="Ghost Mode" />
                                                        <ComboBox x:Name="GhostModeDropdown" AutomationProperties.Name="Ghost Mode for this fence">
                                                            <ComboBoxItem Content="Use Global Setting" />
                                                            <ComboBoxItem Content="Force Enable (Always Hide)" />
                                                            <ComboBoxItem Content="Force Disable (Always Show)" />
                                                        </ComboBox>
                                                    </StackPanel>
                                                </Grid>

                                                <ui:ToggleSwitch x:Name="EnableSearchToggle" Margin="0,16,0,0"
                                                                 Content="Show the search box in this fence" />
                                            </StackPanel>
                                        </Border>

                                        <Border Style="{StaticResource CardPanel}">
                                            <StackPanel>
                                                <TextBlock Text="Auto-organise" FontWeight="SemiBold" Margin="0,0,0,4" />
                                                <TextBlock Style="{StaticResource FieldLabel}" TextWrapping="Wrap"
                                                           Text="Sweep matching file types off the Desktop into this fence." />
                                                <Grid Margin="0,10,0,0">
                                                    <Grid.ColumnDefinitions>
                                                        <ColumnDefinition Width="160" />
                                                        <ColumnDefinition Width="*" />
                                                    </Grid.ColumnDefinitions>
                                                    <ComboBox x:Name="PresetDropdown" AutomationProperties.Name="File type preset" Grid.Column="0" Margin="0,0,10,0"
                                                              SelectionChanged="PresetDropdown_SelectionChanged">
                                                        <ComboBoxItem Content="Custom..." />
                                                        <ComboBoxItem Content="Images &amp; Photos" />
                                                        <ComboBoxItem Content="Documents" />
                                                        <ComboBoxItem Content="Audio &amp; Music" />
                                                        <ComboBoxItem Content="Videos" />
                                                        <ComboBoxItem Content="Archives (.zip)" />
                                                        <ComboBoxItem Content="Apps &amp; Shortcuts" />
                                                    </ComboBox>
                                                    <ui:TextBox x:Name="AutoSortInput" AutomationProperties.Name="File extensions to sweep into this fence" Grid.Column="1"
                                                                PlaceholderText=".jpg, .png, .gif" />
                                                </Grid>
                                            </StackPanel>
                                        </Border>

                                        <Border Style="{StaticResource CardPanel}">
                                            <StackPanel>
                                                <TextBlock Text="Appearance" FontWeight="SemiBold" Margin="0,0,0,12" />

                                                <Border CornerRadius="6" Padding="12,10" Margin="0,0,0,14"
                                                        Background="{DynamicResource ControlFillColorSecondaryBrush}"
                                                        BorderBrush="{DynamicResource ControlElevationBorderBrush}"
                                                        BorderThickness="1">
                                                    <Grid>
                                                        <Grid.ColumnDefinitions>
                                                            <ColumnDefinition Width="*" />
                                                            <ColumnDefinition Width="Auto" />
                                                        </Grid.ColumnDefinitions>
                                                        <StackPanel Grid.Column="0" VerticalAlignment="Center">
                                                            <TextBlock x:Name="ColorSourceText" FontWeight="SemiBold"
                                                                       Text="Colour is coming from the theme" />
                                                            <TextBlock x:Name="ColorSourceHint" Style="{StaticResource FieldLabel}"
                                                                       Margin="0,4,0,0" TextWrapping="Wrap"
                                                                       Text="Switching themes will restyle this fence." />
                                                        </StackPanel>
                                                        <ui:Button x:Name="UseThemeColorBtn" Grid.Column="1"
                                                                   Padding="14,6" Content="Use theme colour"
                                                                   VerticalAlignment="Center"
                                                                   Visibility="Collapsed"
                                                                   Click="UseThemeColor_Click" />
                                                    </Grid>
                                                </Border>

                                                <StackPanel Orientation="Horizontal" Margin="0,0,0,14">
                                                    <ui:ToggleSwitch x:Name="BlendWallpaperToggle" Margin="0,0,20,0"
                                                                     Click="BlendWallpaperToggle_Click"
                                                                     Content="Blend into wallpaper" />
                                                    <ui:ToggleSwitch x:Name="AutoMatchToggle"
                                                                     Click="AutoMatchToggle_Click"
                                                                     Content="Auto-match wallpaper colour" />
                                                </StackPanel>

                                                <Grid Margin="0,0,0,10">
                                                    <Grid.ColumnDefinitions>
                                                        <ColumnDefinition Width="86" />
                                                        <ColumnDefinition Width="*" />
                                                    </Grid.ColumnDefinitions>
                                                    <TextBlock Grid.Column="0" VerticalAlignment="Center" Text="Hue" Style="{StaticResource FieldLabel}" />
                                                    <Slider x:Name="HueSlider" Style="{StaticResource GradientSlider}" AutomationProperties.Name="Hue" Grid.Column="1" Maximum="360" Minimum="0" ValueChanged="ColorSlider_ValueChanged">
                                                        <Slider.Background>
                                                            <LinearGradientBrush EndPoint="1,0">
                                                                <GradientStop Offset="0" Color="Red" />
                                                                <GradientStop Offset="0.16" Color="Yellow" />
                                                                <GradientStop Offset="0.33" Color="Lime" />
                                                                <GradientStop Offset="0.5" Color="Cyan" />
                                                                <GradientStop Offset="0.66" Color="Blue" />
                                                                <GradientStop Offset="0.83" Color="Magenta" />
                                                                <GradientStop Offset="1" Color="Red" />
                                                            </LinearGradientBrush>
                                                        </Slider.Background>
                                                    </Slider>
                                                </Grid>
                                                <Grid Margin="0,0,0,10">
                                                    <Grid.ColumnDefinitions>
                                                        <ColumnDefinition Width="86" />
                                                        <ColumnDefinition Width="*" />
                                                    </Grid.ColumnDefinitions>
                                                    <TextBlock Grid.Column="0" VerticalAlignment="Center" Text="Brightness" Style="{StaticResource FieldLabel}" />
                                                    <Slider x:Name="LightnessSlider" Style="{StaticResource GradientSlider}" AutomationProperties.Name="Lightness" Grid.Column="1" Maximum="100" Minimum="0" Value="50" ValueChanged="ColorSlider_ValueChanged">
                                                        <Slider.Background>
                                                            <LinearGradientBrush EndPoint="1,0">
                                                                <GradientStop Offset="0" Color="Black" />
                                                                <GradientStop x:Name="BrightnessEndColor" Offset="0.5" Color="#00A2FF" />
                                                                <GradientStop Offset="1" Color="White" />
                                                            </LinearGradientBrush>
                                                        </Slider.Background>
                                                    </Slider>
                                                </Grid>
                                                <Grid Margin="0,0,0,10">
                                                    <Grid.ColumnDefinitions>
                                                        <ColumnDefinition Width="86" />
                                                        <ColumnDefinition Width="*" />
                                                    </Grid.ColumnDefinitions>
                                                    <TextBlock Grid.Column="0" VerticalAlignment="Center" Text="Saturation" Style="{StaticResource FieldLabel}" />
                                                    <Slider x:Name="SaturationSlider" Style="{StaticResource GradientSlider}" AutomationProperties.Name="Saturation" Grid.Column="1" Maximum="100" Minimum="0" Value="100" ValueChanged="ColorSlider_ValueChanged">
                                                        <Slider.Background>
                                                            <LinearGradientBrush EndPoint="1,0">
                                                                <GradientStop x:Name="SaturationStartColor" Offset="0" Color="#808080" />
                                                                <GradientStop x:Name="SaturationEndColor" Offset="1" Color="#00A2FF" />
                                                            </LinearGradientBrush>
                                                        </Slider.Background>
                                                    </Slider>
                                                </Grid>
                                                <Grid Margin="0,0,0,10">
                                                    <Grid.ColumnDefinitions>
                                                        <ColumnDefinition Width="86" />
                                                        <ColumnDefinition Width="*" />
                                                        <ColumnDefinition Width="Auto" />
                                                    </Grid.ColumnDefinitions>
                                                    <TextBlock Grid.Column="0" VerticalAlignment="Center" Text="Opacity" Style="{StaticResource FieldLabel}" />
                                                    <Slider x:Name="AlphaSlider" Style="{StaticResource GradientSlider}" AutomationProperties.Name="Opacity" Grid.Column="1" Maximum="100" Minimum="0" Value="70" ValueChanged="ColorSlider_ValueChanged">
                                                        <Slider.Background>
                                                            <LinearGradientBrush EndPoint="1,0">
                                                                <GradientStop Offset="0" Color="#00000000" />
                                                                <GradientStop x:Name="AlphaEndColor" Offset="1" Color="#00A2FF" />
                                                            </LinearGradientBrush>
                                                        </Slider.Background>
                                                    </Slider>
                                                    <Border x:Name="ColorPreview" Grid.Column="2" Width="34" Height="22"
                                                            Margin="12,0,0,0" CornerRadius="4"
                                                            BorderBrush="{DynamicResource ControlElevationBorderBrush}"
                                                            BorderThickness="1" />
                                                </Grid>
                                            </StackPanel>
                                        </Border>

                                        <Border Style="{StaticResource CardPanel}">
                                            <StackPanel>
                                                <TextBlock Text="Background video" FontWeight="SemiBold" Margin="0,0,0,4" />
                                                <TextBlock Style="{StaticResource FieldLabel}" TextWrapping="Wrap"
                                                           Text="Each theme ships an 8-second loop, applied automatically when you pick it. You can point at any .mp4 instead, including Wallpaper Engine files." />
                                                <Grid Margin="0,10,0,10">
                                                    <Grid.ColumnDefinitions>
                                                        <ColumnDefinition Width="*" />
                                                        <ColumnDefinition Width="Auto" />
                                                        <ColumnDefinition Width="Auto" />
                                                    </Grid.ColumnDefinitions>
                                                    <ui:TextBox x:Name="MediaFilePathInput" AutomationProperties.Name="Background video file path" Grid.Column="0" IsReadOnly="True" />
                                                    <ui:Button Grid.Column="1" Margin="8,0,0,0" Padding="14,6"
                                                               Content="Browse" Click="BrowseMedia_Click" />
                                                    <ui:Button Grid.Column="2" Margin="8,0,0,0" Padding="14,6"
                                                               Content="Clear" Click="ClearMedia_Click" />
                                                </Grid>
                                                <Grid>
                                                    <Grid.ColumnDefinitions>
                                                        <ColumnDefinition Width="86" />
                                                        <ColumnDefinition Width="*" />
                                                    </Grid.ColumnDefinitions>
                                                    <TextBlock Grid.Column="0" VerticalAlignment="Center" Text="Opacity" Style="{StaticResource FieldLabel}" />
                                                    <Slider x:Name="MediaOpacitySlider" AutomationProperties.Name="Background video opacity" Grid.Column="1" Maximum="100" Minimum="0" Value="100" />
                                                </Grid>
                                            </StackPanel>
                                        </Border>

                                        <Border Style="{StaticResource CardPanel}" Margin="0,4,0,24">
                                            <Grid>
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="*" />
                                                    <ColumnDefinition Width="Auto" />
                                                </Grid.ColumnDefinitions>
                                                <StackPanel Grid.Column="0" VerticalAlignment="Center" Margin="0,0,16,0">
                                                    <TextBlock Text="Delete this fence" FontWeight="SemiBold" />
                                                    <TextBlock Style="{StaticResource FieldLabel}" Margin="0,4,0,0" TextWrapping="Wrap"
                                                               Text="You'll be able to undo this straight afterwards." />
                                                </StackPanel>
                                                <ui:Button x:Name="DeleteFenceBtn" Grid.Column="1" Appearance="Danger"
                                                           Padding="16,8" VerticalAlignment="Center"
                                                           Content="Delete fence" Icon="{ui:SymbolIcon Symbol=Delete24}"
                                                           Click="DeleteFenceBtn_Click" />
                                            </Grid>
                                        </Border>
                                    </StackPanel>
                                </ScrollViewer>
                            </Grid>
                        </Grid>

                        <StackPanel x:Name="ThemeEditorGrid" Visibility="Collapsed">
                            <TextBlock Style="{StaticResource PageTitle}" Text="Themes" />
                            <TextBlock Style="{StaticResource PageSubtitle}"
                                       Text="Applies to every fence. Selecting a theme applies it immediately." />

                            <Grid Margin="0,0,0,12">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="Auto" />
                                </Grid.ColumnDefinitions>
                                <ui:TextBox x:Name="ThemeFilter" AutomationProperties.Name="Filter themes by name" Grid.Column="0" Margin="0,0,10,0"
                                            PlaceholderText="Filter themes"
                                            Icon="{ui:SymbolIcon Symbol=Search24}"
                                            TextChanged="ThemeFilter_TextChanged" />
                                <StackPanel Grid.Column="1" Orientation="Horizontal">

<Button x:Name="GenerateThemeButton" Style="{StaticResource AccentButton}"
                                            AutomationProperties.Name="Generate a theme from your desktop wallpaper"
                                            Margin="0,0,8,0" Click="GenerateTheme_Click"
                                            ToolTip="Build a theme from the colours in your wallpaper">
                                        <StackPanel Orientation="Horizontal" TextElement.Foreground="{DynamicResource CustomTextOnAccentBrush}">
                                            <ui:SymbolIcon Symbol="Wand24" FontSize="16" Margin="0,0,8,0"
                                                           Foreground="{DynamicResource CustomTextOnAccentBrush}" />
                                            <TextBlock Text="Generate from desktop" VerticalAlignment="Center"
                                                       Foreground="{DynamicResource CustomTextOnAccentBrush}" />
                                        </StackPanel>
                                    </Button>
                                    <ui:Button Padding="14,6" Margin="0,0,8,0" Content="Import"
                                               Icon="{ui:SymbolIcon Symbol=ArrowImport24}" Click="ImportTheme_Click"
                                               ToolTip="Import a .fftheme package or theme .json" />
                                    <ui:Button Padding="14,6" Content="Export"
                                               Icon="{ui:SymbolIcon Symbol=ArrowExport24}" Click="ExportTheme_Click"
                                               ToolTip="Share the current theme as a .fftheme package" />
                                </StackPanel>
                            </Grid>

                            <ListBox x:Name="ThemeGallery"
                                     ItemTemplate="{StaticResource ThemeSwatchTemplate}"
                                     Background="Transparent" BorderThickness="0"
                                     ScrollViewer.HorizontalScrollBarVisibility="Disabled"
                                     KeyboardNavigation.DirectionalNavigation="Contained"
                                     PreviewKeyDown="ThemeGallery_KeyDown"
                                     KeyDown="ThemeGallery_ContextMenuKey"
                                     AutomationProperties.Name="Theme gallery">
                                <ListBox.ItemsPanel>
                                    <ItemsPanelTemplate>
                                        <WrapPanel Orientation="Horizontal" />
                                    </ItemsPanelTemplate>
                                </ListBox.ItemsPanel>
                                <ListBox.ItemContainerStyle>
                                    <Style TargetType="ListBoxItem">

                                        <Setter Property="AutomationProperties.Name" Value="{Binding Name}" />
                                        <Setter Property="Padding" Value="0" />
                                        <Setter Property="Margin" Value="0" />
                                        <Setter Property="Background" Value="Transparent" />
                                        <Setter Property="Focusable" Value="True" />
                                        <Setter Property="Template">
                                            <Setter.Value>
                                                <ControlTemplate TargetType="ListBoxItem">
                                                    <Grid>
                                                        <ContentPresenter />

                                                        <Border x:Name="FocusRing"
                                                                Margin="-3"
                                                                CornerRadius="10"
                                                                BorderThickness="2"
                                                                BorderBrush="{DynamicResource CustomFocusRingBrush}"
                                                                Visibility="Collapsed"
                                                                SnapsToDevicePixels="True" />
                                                    </Grid>
                                                    <ControlTemplate.Triggers>
                                                        <Trigger Property="IsKeyboardFocused" Value="True">
                                                            <Setter TargetName="FocusRing" Property="Visibility" Value="Visible" />
                                                        </Trigger>
                                                    </ControlTemplate.Triggers>
                                                </ControlTemplate>
                                            </Setter.Value>
                                        </Setter>
                                    </Style>
                                </ListBox.ItemContainerStyle>
                            </ListBox>

                            <TextBlock Style="{StaticResource SectionHeader}" Text="Motion" />
                            <Border Style="{StaticResource CardPanel}" Margin="0,0,0,24">
                                <StackPanel>
                                    <TextBlock Style="{StaticResource FieldLabel}" Text="Roll-up animation" />
                                    <ComboBox x:Name="AnimationDropdown" AutomationProperties.Name="Roll-up animation" Width="220" HorizontalAlignment="Left">
                                        <ComboBoxItem Content="Smooth" />
                                        <ComboBoxItem Content="Bounce" />
                                        <ComboBoxItem Content="Linear" />
                                        <ComboBoxItem Content="None" />
                                    </ComboBox>
                                </StackPanel>
                            </Border>
                        </StackPanel>

                        <StackPanel x:Name="HowToGrid" Visibility="Collapsed">
                            <TextBlock Style="{StaticResource PageTitle}" Text="How to use" />
                            <TextBlock Style="{StaticResource PageSubtitle}"
                                       Text="The short version: right-click the tray icon to make a fence, then drag things into it." />

                            <TextBlock Style="{StaticResource SectionHeader}" Text="Keyboard shortcuts" Margin="0,0,0,12" />
                            <Border Style="{StaticResource CardPanel}">
                                <StackPanel x:Name="ShortcutList" />
                            </Border>

                            <TextBlock Style="{StaticResource SectionHeader}" Text="The basics" />
                            <Border Style="{StaticResource CardPanel}">
                                <StackPanel x:Name="BasicsList" />
                            </Border>

                            <TextBlock Style="{StaticResource SectionHeader}" Text="Tabs and merging" />
                            <Border Style="{StaticResource CardPanel}" Margin="0,0,0,24">
                                <StackPanel x:Name="TabsList" />
                            </Border>
                        </StackPanel>

                        <StackPanel x:Name="FeedbackGrid" Visibility="Collapsed">
                            <TextBlock Style="{StaticResource PageTitle}" Text="Feedback" />
                            <TextBlock Style="{StaticResource PageSubtitle}"
                                       Text="Bugs, ideas and awkward corners are all welcome." />

                            <Border Style="{StaticResource CardPanel}">
                                <StackPanel>
                                    <TextBlock Text="Ask a question" FontWeight="SemiBold" />
                                    <TextBlock Style="{StaticResource FieldLabel}" Margin="0,4,0,10" TextWrapping="Wrap"
                                               Text="Something not behaving the way you expected?" />
                                    <ui:Button HorizontalAlignment="Left" Padding="16,8" Content="Open a question"
                                               Icon="{ui:SymbolIcon Symbol=ChatHelp24}" Click="AskAQuestion_Click" />
                                </StackPanel>
                            </Border>
                            <Border Style="{StaticResource CardPanel}">
                                <StackPanel>
                                    <TextBlock Text="Suggest an idea" FontWeight="SemiBold" />
                                    <TextBlock Style="{StaticResource FieldLabel}" Margin="0,4,0,10" TextWrapping="Wrap"
                                               Text="Missing something that would make this fit your desktop better?" />
                                    <ui:Button HorizontalAlignment="Left" Padding="16,8" Content="Suggest a feature"
                                               Icon="{ui:SymbolIcon Symbol=Lightbulb24}" Click="SuggestAnIdea_Click" />
                                </StackPanel>
                            </Border>
                        </StackPanel>
                    </Grid>
                </ScrollViewer>
            </Border>
        </Grid>

        <Border x:Name="StatusStrip" Grid.Row="2" Margin="12,0,12,12" Padding="14,10"
                CornerRadius="6" Visibility="Collapsed"
                Background="{DynamicResource ControlFillColorDefaultBrush}"
                BorderBrush="{DynamicResource ControlElevationBorderBrush}"
                BorderThickness="1">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>
                <ui:SymbolIcon x:Name="StatusIcon" Grid.Column="0" Symbol="CheckmarkCircle24"
                               Margin="0,0,10,0" VerticalAlignment="Center" />
                <TextBlock x:Name="StatusText" Grid.Column="1" VerticalAlignment="Center"
                           TextWrapping="Wrap"
                           Foreground="{DynamicResource TextFillColorPrimaryBrush}" />
                <ui:Button x:Name="StatusUndo" Grid.Column="2" Content="Undo" Appearance="Secondary"
                           Margin="8,0,0,0" Padding="12,4" Visibility="Collapsed"
                           Click="StatusUndo_Click" />
                <ui:Button Grid.Column="3" Margin="8,0,0,0" Padding="6,4" Appearance="Transparent"
                           Icon="{ui:SymbolIcon Symbol=Dismiss24}" Click="StatusDismiss_Click"
                           ToolTip="Dismiss" />
            </Grid>
        </Border>
    </Grid>
</ui:FluentWindow>
