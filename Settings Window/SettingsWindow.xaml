<Window
    x:Class="DesktopFences.SettingsWindow"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    Title="Fluid Fences Settings"
    Width="950"
    Height="680"
    Background="#1E1E1E"
    FontFamily="Segoe UI Variable, Segoe UI, Arial"
    Foreground="White"
    WindowStartupLocation="CenterScreen">

    <Window.Resources>
        <Style TargetType="TabControl">
            <Setter Property="Background" Value="Transparent" />
            <Setter Property="BorderThickness" Value="0" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="TabControl">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="220" />
                                <ColumnDefinition Width="*" />
                            </Grid.ColumnDefinitions>
                            <Border
                                Grid.Column="0"
                                Background="#151515"
                                BorderBrush="#333"
                                BorderThickness="0,0,1,0" />
                            <StackPanel
                                Grid.Column="0"
                                Margin="0,20,0,0"
                                IsItemsHost="True" />
                            <ContentPresenter
                                x:Name="PART_SelectedContentHost"
                                Grid.Column="1"
                                Margin="20"
                                ContentSource="SelectedContent" />
                        </Grid>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style TargetType="TabItem">
            <Setter Property="Background" Value="Transparent" />
            <Setter Property="Foreground" Value="#AAAAAA" />
            <Setter Property="FontSize" Value="14" />
            <Setter Property="Padding" Value="20,15" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="TabItem">
                        <Border
                            x:Name="Border"
                            Margin="5,2"
                            Padding="{TemplateBinding Padding}"
                            Background="{TemplateBinding Background}"
                            CornerRadius="4">
                            <ContentPresenter
                                HorizontalAlignment="Left"
                                VerticalAlignment="Center"
                                ContentSource="Header" />
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsSelected" Value="True">
                                <Setter TargetName="Border" Property="Background" Value="#333333" />
                                <Setter Property="Foreground" Value="White" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style TargetType="TextBox">
            <Setter Property="Background" Value="#2D2D2D" />
            <Setter Property="Foreground" Value="White" />
            <Setter Property="BorderBrush" Value="#444444" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="Padding" Value="8,5" />
            <Setter Property="CaretBrush" Value="White" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="TextBox">
                        <Border
                            x:Name="border"
                            Background="{TemplateBinding Background}"
                            BorderBrush="{TemplateBinding BorderBrush}"
                            BorderThickness="{TemplateBinding BorderThickness}"
                            CornerRadius="4">
                            <ScrollViewer
                                x:Name="PART_ContentHost"
                                Focusable="false"
                                HorizontalScrollBarVisibility="Hidden"
                                VerticalScrollBarVisibility="Hidden" />
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="true">
                                <Setter TargetName="border" Property="BorderBrush" Value="#666666" />
                            </Trigger>
                            <Trigger Property="IsFocused" Value="true">
                                <Setter TargetName="border" Property="BorderBrush" Value="#0078D7" />
                                <Setter TargetName="border" Property="BorderThickness" Value="1" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style TargetType="ComboBox">
            <Setter Property="Background" Value="#2D2D2D" />
            <Setter Property="Foreground" Value="White" />
            <Setter Property="BorderBrush" Value="#444444" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="Height" Value="32" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ComboBox">
                        <Grid>
                            <ToggleButton
                                x:Name="ToggleButton"
                                Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                IsChecked="{Binding IsDropDownOpen, Mode=TwoWay, RelativeSource={RelativeSource TemplatedParent}}">
                                <ToggleButton.Template>
                                    <ControlTemplate TargetType="ToggleButton">
                                        <Border
                                            Background="{TemplateBinding Background}"
                                            BorderBrush="{TemplateBinding BorderBrush}"
                                            BorderThickness="{TemplateBinding BorderThickness}"
                                            CornerRadius="4">
                                            <Path
                                                Margin="0,0,10,0"
                                                HorizontalAlignment="Right"
                                                VerticalAlignment="Center"
                                                Data="M 0 0 L 4 4 L 8 0 Z"
                                                Fill="White" />
                                        </Border>
                                    </ControlTemplate>
                                </ToggleButton.Template>
                            </ToggleButton>
                            <ContentPresenter
                                x:Name="ContentSite"
                                Margin="10,0,30,0"
                                HorizontalAlignment="Left"
                                VerticalAlignment="Center"
                                Content="{TemplateBinding SelectionBoxItem}"
                                IsHitTestVisible="False"
                                TextElement.Foreground="White" />
                            <Popup
                                x:Name="Popup"
                                AllowsTransparency="True"
                                Focusable="False"
                                IsOpen="{TemplateBinding IsDropDownOpen}"
                                Placement="Bottom">
                                <Border
                                    Margin="0,2,0,0"
                                    Background="#2D2D2D"
                                    BorderBrush="#444"
                                    BorderThickness="1"
                                    CornerRadius="4">
                                    <ScrollViewer>
                                        <StackPanel IsItemsHost="True" />
                                    </ScrollViewer>
                                </Border>
                            </Popup>
                        </Grid>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style TargetType="ComboBoxItem">
            <Setter Property="Background" Value="#2D2D2D" />
            <Setter Property="Foreground" Value="White" />
            <Setter Property="Padding" Value="8,5" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ComboBoxItem">
                        <Border
                            x:Name="gd"
                            Padding="{TemplateBinding Padding}"
                            Background="{TemplateBinding Background}">
                            <ContentPresenter />
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsSelected" Value="True">
                                <Setter TargetName="gd" Property="Background" Value="#0078D7" />
                            </Trigger>
                            <Trigger Property="IsHighlighted" Value="True">
                                <Setter TargetName="gd" Property="Background" Value="#444444" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style TargetType="Button">
            <Setter Property="Background" Value="#333333" />
            <Setter Property="Foreground" Value="White" />
            <Setter Property="BorderThickness" Value="0" />
            <Setter Property="Cursor" Value="Hand" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border
                            x:Name="BtnBorder"
                            Background="{TemplateBinding Background}"
                            BorderBrush="{TemplateBinding BorderBrush}"
                            BorderThickness="{TemplateBinding BorderThickness}"
                            CornerRadius="4">
                            <ContentPresenter
                                Margin="{TemplateBinding Padding}"
                                HorizontalAlignment="Center"
                                VerticalAlignment="Center" />
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="BtnBorder" Property="Background" Value="#555555" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style
            x:Key="PrimaryButton"
            BasedOn="{StaticResource {x:Type Button}}"
            TargetType="Button">
            <Setter Property="Background" Value="#0078D7" />
        </Style>
        <Style
            x:Key="DangerButton"
            BasedOn="{StaticResource {x:Type Button}}"
            TargetType="Button">
            <Setter Property="Background" Value="Transparent" />
            <Setter Property="Foreground" Value="#FF4444" />
            <Setter Property="BorderBrush" Value="#FF4444" />
            <Setter Property="BorderThickness" Value="1" />
        </Style>
        <Style x:Key="ImageButtonStyle" TargetType="Button">
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="Transparent">
                            <ContentPresenter />
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
            <Setter Property="Cursor" Value="Hand" />
        </Style>
        <Style x:Key="SectionHeader" TargetType="TextBlock">
            <Setter Property="FontSize" Value="18" />
            <Setter Property="FontWeight" Value="SemiBold" />
            <Setter Property="Margin" Value="0,0,0,15" />
            <Setter Property="Foreground" Value="White" />
        </Style>

        <Style x:Key="ToggleSwitchStyle" TargetType="CheckBox">
            <Setter Property="Foreground" Value="White" />
            <Setter Property="Cursor" Value="Hand" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="CheckBox">
                        <StackPanel Background="Transparent" Orientation="Horizontal">
                            <Border
                                x:Name="Border"
                                Width="40"
                                Height="20"
                                Margin="0,0,10,0"
                                Background="#444"
                                CornerRadius="10">
                                <Ellipse
                                    x:Name="Knob"
                                    Width="14"
                                    Height="14"
                                    Margin="3,0,0,0"
                                    HorizontalAlignment="Left"
                                    Fill="White" />
                            </Border>
                            <ContentPresenter VerticalAlignment="Center" />
                        </StackPanel>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsChecked" Value="True">
                                <Setter TargetName="Border" Property="Background" Value="#0078D7" />
                                <Setter TargetName="Knob" Property="HorizontalAlignment" Value="Right" />
                                <Setter TargetName="Knob" Property="Margin" Value="0,0,3,0" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="BlueSliderStyle" TargetType="Slider">
            <Setter Property="Margin" Value="10,0,0,0" />
            <Setter Property="IsSnapToTickEnabled" Value="True" />
            <Setter Property="TickFrequency" Value="1" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Slider">
                        <Grid>
                            <Border
                                Height="4"
                                VerticalAlignment="Center"
                                Background="{TemplateBinding Background}"
                                CornerRadius="2" />
                            <Track x:Name="PART_Track">
                                <Track.Thumb>
                                    <Thumb Width="14" Height="22">
                                        <Thumb.Template>
                                            <ControlTemplate>
                                                <Path Data="M0,0 L14,0 L14,14 L7,22 L0,14 Z" Fill="#0078D7" />
                                            </ControlTemplate>
                                        </Thumb.Template>
                                    </Thumb>
                                </Track.Thumb>
                            </Track>
                        </Grid>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
        <Style x:Key="WhiteSliderStyle" TargetType="Slider">
            <Setter Property="Margin" Value="10,0,0,0" />
            <Setter Property="IsSnapToTickEnabled" Value="True" />
            <Setter Property="TickFrequency" Value="1" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Slider">
                        <Grid>
                            <Border
                                Height="4"
                                VerticalAlignment="Center"
                                Background="{TemplateBinding Background}"
                                CornerRadius="2" />
                            <Track x:Name="PART_Track">
                                <Track.Thumb>
                                    <Thumb Width="14" Height="22">
                                        <Thumb.Template>
                                            <ControlTemplate>
                                                <Path Data="M0,0 L14,0 L14,14 L7,22 L0,14 Z" Fill="#DDDDDD" />
                                            </ControlTemplate>
                                        </Thumb.Template>
                                    </Thumb>
                                </Track.Thumb>
                            </Track>
                        </Grid>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

    </Window.Resources>

    <Grid>
        <TabControl SelectedIndex="0">

            <TabItem Header="About">
                <Grid Margin="40">
                    <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center">
                        <Border
                            Width="120"
                            Height="120"
                            Margin="0,0,0,20"
                            HorizontalAlignment="Center">
                            <Image Source="/Assets/FluidFences16BitLogo.png" Stretch="Uniform" />
                        </Border>
                        <TextBlock
                            Margin="0,0,0,20"
                            HorizontalAlignment="Center"
                            FontSize="32"
                            FontWeight="Bold"
                            Text="Fluid Fences" />
                        <TextBlock
                            x:Name="AboutDescriptionText"
                            MaxWidth="500"
                            FontSize="14"
                            Foreground="#CCCCCC"
                            Text="Fluid Fences is a streamlined solution for organizing your desktop. Create, resize, and manage your fence regions effortlessly."
                            TextAlignment="Center"
                            TextWrapping="Wrap" />
                        <TextBlock
                            Margin="0,30,0,0"
                            HorizontalAlignment="Center"
                            FontSize="18"
                            Foreground="#AAAAAA"
                            Text="Buy me a coffee ☕" />
                        <Button
                            Margin="0,10,0,0"
                            HorizontalAlignment="Center"
                            Click="BuyMeACoffee_Click"
                            Style="{StaticResource ImageButtonStyle}">
                            <Image
                                Width="200"
                                Height="215"
                                Source="/Settings Window/BuyMeACoffeeQR.png"
                                Stretch="Uniform" />
                        </Button>
                    </StackPanel>
                </Grid>
            </TabItem>

            <TabItem Header="How to use">
                <ScrollViewer
                    Margin="40,20"
                    HorizontalScrollBarVisibility="Disabled"
                    VerticalScrollBarVisibility="Auto">
                    <StackPanel Margin="0,0,15,0">
                        <TextBlock
                            Margin="0,0,0,25"
                            FontSize="26"
                            FontWeight="Bold"
                            Foreground="White"
                            Text="How to Use Fluid Fences" />
                        <TextBlock Style="{StaticResource SectionHeader}" Text="Basic Controls" />
                        <TextBlock
                            Margin="0,0,0,8"
                            FontSize="14"
                            Foreground="#CCCCCC"
                            Text="• Move a Fence: Click and drag the top title bar to move a fence anywhere on your screen."
                            TextWrapping="Wrap" />
                        <TextBlock
                            Margin="0,0,0,8"
                            FontSize="14"
                            Foreground="#CCCCCC"
                            Text="• Resize: Hover over any edge or corner until you see the sizing arrows, then click and drag to stretch the fence."
                            TextWrapping="Wrap" />
                        <TextBlock
                            Margin="0,0,0,25"
                            FontSize="14"
                            Foreground="#CCCCCC"
                            Text="• Roll-up: Double-click the title bar to collapse the fence and save screen space. Simply hover your mouse over the rolled-up bar to temporarily reveal its contents."
                            TextWrapping="Wrap" />
                        <TextBlock Style="{StaticResource SectionHeader}" Text="Managing Icons" />
                        <TextBlock
                            Margin="0,0,0,8"
                            FontSize="14"
                            Foreground="#CCCCCC"
                            Text="• Add Files: Drag and drop any desktop shortcut, file, or folder directly into the fence."
                            TextWrapping="Wrap" />
                        <TextBlock
                            Margin="0,0,0,8"
                            FontSize="14"
                            Foreground="#CCCCCC"
                            Text="• Select Multiple: Click and drag an empty area inside the fence to draw a blue selection box around multiple items."
                            TextWrapping="Wrap" />
                        <TextBlock
                            Margin="0,0,0,8"
                            FontSize="14"
                            Foreground="#CCCCCC"
                            Text="• Search: Click the magnifying glass (🔍) in the header to instantly filter and find files by name."
                            TextWrapping="Wrap" />
                        <TextBlock
                            Margin="0,0,0,25"
                            FontSize="14"
                            Foreground="#CCCCCC"
                            Text="• Rename Files: Right-click any icon and select 'Rename File' or double-click the file name text to edit it directly."
                            TextWrapping="Wrap" />
                        <TextBlock Style="{StaticResource SectionHeader}" Text="Customization" />
                        <TextBlock
                            Margin="0,0,0,8"
                            FontSize="14"
                            Foreground="#CCCCCC"
                            Text="• The Main Menu: Right-click the title bar (or click the ☰ hamburger icon) to access settings, sorting, and display options."
                            TextWrapping="Wrap" />
                        <TextBlock
                            Margin="0,0,0,8"
                            FontSize="14"
                            Foreground="#CCCCCC"
                            Text="• Icon Size: Change the icon scale (Small, Medium, Large) from the 'View' menu."
                            TextWrapping="Wrap" />
                        <TextBlock
                            Margin="0,0,0,25"
                            FontSize="14"
                            Foreground="#CCCCCC"
                            Text="• Colors: Use the 'Edit Colors' tab in Settings to perfectly match the fence to your wallpaper in real-time."
                            TextWrapping="Wrap" />
                    </StackPanel>
                </ScrollViewer>
            </TabItem>

            <TabItem Header="General">
                <Grid Margin="40">
                    <StackPanel>
                        <TextBlock Style="{StaticResource SectionHeader}" Text="Global Application Settings" />
                        <TextBlock
                            Margin="0,0,0,20"
                            Foreground="#AAA"
                            Text="These settings apply to all of your fences." />

                        <CheckBox
                            x:Name="StartupToggle"
                            Margin="0,0,0,15"
                            Content="Run Fluid Fences automatically when Windows starts"
                            Style="{StaticResource ToggleSwitchStyle}" />
                        <CheckBox
                            x:Name="TaskbarToggle"
                            Margin="0,0,0,30"
                            Content="Show Fences in the Windows Taskbar"
                            Style="{StaticResource ToggleSwitchStyle}" />

                        <Button
                            Padding="20,10"
                            HorizontalAlignment="Left"
                            Click="SaveGlobalSettings_Click"
                            Content="Save General Settings"
                            Style="{StaticResource PrimaryButton}" />
                    </StackPanel>
                </Grid>
            </TabItem>

            <TabItem Header="Fences">
                <Grid Margin="40">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="200" />
                        <ColumnDefinition Width="*" />
                    </Grid.ColumnDefinitions>
                    <StackPanel Grid.Column="0" Margin="0,0,30,0">
                        <TextBlock Style="{StaticResource SectionHeader}" Text="Select a Fence" />
                        <ListBox
                            x:Name="FenceListBox"
                            Height="400"
                            Background="#151515"
                            BorderBrush="#333"
                            Foreground="White"
                            SelectionChanged="FenceListBox_SelectionChanged" />
                    </StackPanel>
                    <ScrollViewer
                        Grid.Column="1"
                        Margin="20,0,0,0"
                        HorizontalScrollBarVisibility="Disabled"
                        VerticalScrollBarVisibility="Auto">
                        <StackPanel Margin="0,0,15,0">
                            <TextBlock Style="{StaticResource SectionHeader}" Text="Fence Settings" />
                            <TextBlock
                                Margin="0,0,0,5"
                                Foreground="#AAA"
                                Text="Fence Title" />
                            <TextBox x:Name="TitleInput" Margin="0,0,0,20" />
                            <TextBlock
                                Margin="0,0,0,5"
                                Foreground="#AAA"
                                Text="Sort by" />
                            <ComboBox x:Name="SortDropdown" Margin="0,0,0,20">
                                <ComboBoxItem Content="None" />
                                <ComboBoxItem Content="Name" />
                                <ComboBoxItem Content="Size" />
                                <ComboBoxItem Content="Item Type" />
                                <ComboBoxItem Content="Date Modified" />
                                <ComboBoxItem Content="Date Created" />
                                <ComboBoxItem Content="Date added to Fence" />
                            </ComboBox>
                            <TextBlock
                                Margin="0,10,0,15"
                                FontSize="16"
                                Style="{StaticResource SectionHeader}"
                                Text="Auto-Sort Engine" />
                            <TextBlock
                                Margin="0,0,0,5"
                                Foreground="#AAA"
                                Text="Select a preset or type custom extensions (e.g. .jpg, .png)"
                                TextWrapping="Wrap" />
                            <Grid Margin="0,0,0,30">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="150" />
                                    <ColumnDefinition Width="*" />
                                </Grid.ColumnDefinitions>
                                <ComboBox
                                    x:Name="PresetDropdown"
                                    Grid.Column="0"
                                    Margin="0,0,10,0"
                                    SelectionChanged="PresetDropdown_SelectionChanged">
                                    <ComboBoxItem Content="Custom..." />
                                    <ComboBoxItem Content="Images &amp; Photos" />
                                    <ComboBoxItem Content="Documents" />
                                    <ComboBoxItem Content="Audio &amp; Music" />
                                    <ComboBoxItem Content="Videos" />
                                    <ComboBoxItem Content="Archives (.zip)" />
                                    <ComboBoxItem Content="Apps &amp; Shortcuts" />
                                </ComboBox>
                                <TextBox x:Name="AutoSortInput" Grid.Column="1" />
                            </Grid>
                            <TextBlock
                                Margin="0,10,0,15"
                                FontSize="16"
                                Style="{StaticResource SectionHeader}"
                                Text="Fence Features" />
                            <CheckBox
                                x:Name="EnableSearchToggle"
                                Margin="0,0,0,20"
                                Content="Enable In-Fence Search Bar"
                                Style="{StaticResource ToggleSwitchStyle}" />
                            <Border
                                Margin="0,10,0,20"
                                BorderBrush="#444"
                                BorderThickness="0,1,0,0" />
                            <Grid Margin="0,0,0,10">
                                <Button
                                    x:Name="DeleteFenceBtn"
                                    Padding="15,8"
                                    HorizontalAlignment="Left"
                                    Click="DeleteFenceBtn_Click"
                                    Content="Delete This Fence"
                                    Style="{StaticResource DangerButton}" />
                                <Button
                                    Padding="20,10"
                                    HorizontalAlignment="Right"
                                    Click="SaveSettings_Click"
                                    Content="Save Changes"
                                    Style="{StaticResource PrimaryButton}" />
                            </Grid>
                        </StackPanel>
                    </ScrollViewer>
                </Grid>
            </TabItem>

            <TabItem Header="   ↳ Edit Colors">
                <Grid Margin="40">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="200" />
                        <ColumnDefinition Width="*" />
                    </Grid.ColumnDefinitions>
                    <StackPanel Grid.Column="0" Margin="0,0,30,0">
                        <TextBlock Style="{StaticResource SectionHeader}" Text="Select a Fence" />
                        <ListBox
                            x:Name="ColorFenceListBox"
                            Height="400"
                            Background="#151515"
                            BorderBrush="#333"
                            Foreground="White"
                            SelectionChanged="FenceListBox_SelectionChanged" />
                    </StackPanel>

                    <ScrollViewer
                        Grid.Column="1"
                        Margin="20,0,0,0"
                        HorizontalScrollBarVisibility="Disabled"
                        VerticalScrollBarVisibility="Auto">
                        <StackPanel Margin="0,0,15,0">

                            <TextBlock
                                x:Name="EditColorTitleText"
                                Style="{StaticResource SectionHeader}"
                                Text="Edit Colors" />

                            <Grid Margin="0,0,0,15">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="Auto" />
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="Auto" />
                                </Grid.ColumnDefinitions>
                                <ComboBox Width="160">
                                    <ComboBoxItem Content="Programs" IsSelected="True" />
                                    <ComboBoxItem Content="Folders" />
                                </ComboBox>
                                <TextBlock
                                    Grid.Column="1"
                                    Margin="15,0,0,0"
                                    VerticalAlignment="Center"
                                    Cursor="Hand"
                                    FontSize="12"
                                    Foreground="#999"
                                    Text="Copy/paste/reset group style" />
                                <TextBlock
                                    Grid.Column="2"
                                    VerticalAlignment="Center"
                                    Cursor="Hand"
                                    FontSize="18"
                                    Foreground="White"
                                    RenderTransformOrigin="0.5,0.5"
                                    Text="🖋"
                                    ToolTip="Pick a color from screen">
                                    <TextBlock.RenderTransform>
                                        <RotateTransform Angle="135" />
                                    </TextBlock.RenderTransform>
                                </TextBlock>
                            </Grid>

                            <CheckBox
                                x:Name="BlendWallpaperToggle"
                                Margin="0,0,0,20"
                                Click="BlendWallpaperToggle_Click"
                                Content="Blend into wallpaper"
                                Foreground="White" />

                            <Grid Margin="0,0,0,15">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="100" />
                                    <ColumnDefinition Width="*" />
                                </Grid.ColumnDefinitions>
                                <TextBlock
                                    VerticalAlignment="Center"
                                    Foreground="#DDD"
                                    Text="Hue:" />
                                <Slider
                                    x:Name="HueSlider"
                                    Grid.Column="1"
                                    Maximum="360"
                                    Minimum="0"
                                    Style="{StaticResource BlueSliderStyle}"
                                    ValueChanged="ColorSlider_ValueChanged">
                                    <Slider.Background>
                                        <LinearGradientBrush EndPoint="1,0">
                                            <GradientStop Offset="0" Color="Red" />
                                            <GradientStop Offset="0.16" Color="Yellow" />
                                            <GradientStop Offset="0.33" Color="Lime" />
                                            <GradientStop Offset="0.5" Color="Cyan" />
                                            <GradientStop Offset="0.66" Color="Blue" />
                                            <GradientStop Offset="0.83" Color="Magenta" />
                                            <GradientStop Offset="1" Color="Red" />
                                        </LinearGradientBrush>
                                    </Slider.Background>
                                </Slider>
                            </Grid>

                            <Grid Margin="0,0,0,15">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="100" />
                                    <ColumnDefinition Width="*" />
                                </Grid.ColumnDefinitions>
                                <TextBlock
                                    VerticalAlignment="Center"
                                    Foreground="#DDD"
                                    Text="Brightness:" />
                                <Slider
                                    x:Name="LightnessSlider"
                                    Grid.Column="1"
                                    Maximum="100"
                                    Minimum="0"
                                    Style="{StaticResource BlueSliderStyle}"
                                    ValueChanged="ColorSlider_ValueChanged"
                                    Value="50">
                                    <Slider.Background>
                                        <LinearGradientBrush EndPoint="1,0">
                                            <GradientStop Offset="0" Color="Black" />
                                            <GradientStop x:Name="BrightnessEndColor" Offset="1" Color="#00A2FF" />
                                        </LinearGradientBrush>
                                    </Slider.Background>
                                </Slider>
                            </Grid>

                            <Grid Margin="0,0,0,15">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="100" />
                                    <ColumnDefinition Width="*" />
                                </Grid.ColumnDefinitions>
                                <TextBlock
                                    VerticalAlignment="Center"
                                    Foreground="#DDD"
                                    Text="Saturation:" />
                                <Slider
                                    x:Name="SaturationSlider"
                                    Grid.Column="1"
                                    Maximum="100"
                                    Minimum="0"
                                    Style="{StaticResource BlueSliderStyle}"
                                    ValueChanged="ColorSlider_ValueChanged"
                                    Value="100">
                                    <Slider.Background>
                                        <LinearGradientBrush EndPoint="1,0">
                                            <GradientStop Offset="0" Color="White" />
                                            <GradientStop x:Name="SaturationEndColor" Offset="1" Color="#00A2FF" />
                                        </LinearGradientBrush>
                                    </Slider.Background>
                                </Slider>
                            </Grid>

                            <Grid Margin="0,0,0,15">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="100" />
                                    <ColumnDefinition Width="*" />
                                </Grid.ColumnDefinitions>
                                <TextBlock
                                    VerticalAlignment="Center"
                                    Foreground="#DDD"
                                    Text="Transparency:" />
                                <Slider
                                    x:Name="AlphaSlider"
                                    Grid.Column="1"
                                    Maximum="100"
                                    Minimum="0"
                                    Style="{StaticResource BlueSliderStyle}"
                                    ValueChanged="ColorSlider_ValueChanged"
                                    Value="70">
                                    <Slider.Background>
                                        <LinearGradientBrush EndPoint="1,0">
                                            <GradientStop Offset="0" Color="#00000000" />
                                            <GradientStop x:Name="AlphaEndColor" Offset="1" Color="#00A2FF" />
                                        </LinearGradientBrush>
                                    </Slider.Background>
                                </Slider>
                            </Grid>

                            <TextBlock
                                Margin="0,5,0,25"
                                Cursor="Hand"
                                FontSize="12"
                                Foreground="#888"
                                Text="More options" />

                            <TextBlock
                                Margin="0,0,0,10"
                                FontSize="14"
                                FontWeight="SemiBold"
                                Text="Edit Icon Tint" />

                            <Border
                                Padding="15"
                                Background="#252525"
                                CornerRadius="6">
                                <StackPanel>
                                    <Grid Margin="0,0,0,20">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="Auto" />
                                            <ColumnDefinition Width="*" />
                                            <ColumnDefinition Width="Auto" />
                                        </Grid.ColumnDefinitions>
                                        <ComboBox Width="200">
                                            <ComboBoxItem Content="Use Fence background color" IsSelected="True" />
                                            <ComboBoxItem Content="Custom Color" />
                                        </ComboBox>
                                        <TextBlock
                                            Grid.Column="2"
                                            VerticalAlignment="Center"
                                            Cursor="Hand"
                                            FontSize="18"
                                            Foreground="#888"
                                            RenderTransformOrigin="0.5,0.5"
                                            Text="🖋"
                                            ToolTip="Pick a color from screen">
                                            <TextBlock.RenderTransform>
                                                <RotateTransform Angle="135" />
                                            </TextBlock.RenderTransform>
                                        </TextBlock>
                                    </Grid>

                                    <Grid Margin="0,0,0,15" Opacity="0.5">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="90" />
                                            <ColumnDefinition Width="*" />
                                        </Grid.ColumnDefinitions>
                                        <TextBlock
                                            VerticalAlignment="Center"
                                            Foreground="#CCC"
                                            Text="Hue:" />
                                        <Slider
                                            x:Name="TintHueSlider"
                                            Grid.Column="1"
                                            IsEnabled="False"
                                            Maximum="360"
                                            Minimum="0"
                                            Style="{StaticResource WhiteSliderStyle}">
                                            <Slider.Background>
                                                <LinearGradientBrush EndPoint="1,0">
                                                    <GradientStop Offset="0" Color="#550000" />
                                                    <GradientStop Offset="0.16" Color="#555500" />
                                                    <GradientStop Offset="0.33" Color="#005500" />
                                                    <GradientStop Offset="0.5" Color="#005555" />
                                                    <GradientStop Offset="0.66" Color="#000055" />
                                                    <GradientStop Offset="0.83" Color="#550055" />
                                                    <GradientStop Offset="1" Color="#550000" />
                                                </LinearGradientBrush>
                                            </Slider.Background>
                                        </Slider>
                                    </Grid>

                                    <Grid Margin="0,0,0,15" Opacity="0.5">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="90" />
                                            <ColumnDefinition Width="*" />
                                        </Grid.ColumnDefinitions>
                                        <TextBlock
                                            VerticalAlignment="Center"
                                            Foreground="#CCC"
                                            Text="Brightness:" />
                                        <Slider
                                            x:Name="TintLightnessSlider"
                                            Grid.Column="1"
                                            IsEnabled="False"
                                            Maximum="100"
                                            Minimum="0"
                                            Style="{StaticResource WhiteSliderStyle}"
                                            Value="50">
                                            <Slider.Background>
                                                <LinearGradientBrush EndPoint="1,0">
                                                    <GradientStop Offset="0" Color="#111" />
                                                    <GradientStop Offset="1" Color="#555" />
                                                </LinearGradientBrush>
                                            </Slider.Background>
                                        </Slider>
                                    </Grid>

                                    <Grid Margin="0,0,0,0" Opacity="0.5">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="90" />
                                            <ColumnDefinition Width="*" />
                                        </Grid.ColumnDefinitions>
                                        <TextBlock
                                            VerticalAlignment="Center"
                                            Foreground="#CCC"
                                            Text="Saturation:" />
                                        <Slider
                                            x:Name="TintSaturationSlider"
                                            Grid.Column="1"
                                            IsEnabled="False"
                                            Maximum="100"
                                            Minimum="0"
                                            Style="{StaticResource WhiteSliderStyle}"
                                            Value="50">
                                            <Slider.Background>
                                                <LinearGradientBrush EndPoint="1,0">
                                                    <GradientStop Offset="0" Color="#444" />
                                                    <GradientStop Offset="1" Color="#644" />
                                                </LinearGradientBrush>
                                            </Slider.Background>
                                        </Slider>
                                    </Grid>
                                </StackPanel>
                            </Border>

                            <Grid Margin="0,15,0,0">
                                <Border
                                    x:Name="ColorPreview"
                                    Width="40"
                                    Height="25"
                                    HorizontalAlignment="Left"
                                    BorderBrush="#555"
                                    BorderThickness="1"
                                    CornerRadius="4" />
                            </Grid>
                        </StackPanel>
                    </ScrollViewer>
                </Grid>
            </TabItem>

            <TabItem Header="Feedback">
                <Grid Margin="40">
                    <StackPanel>
                        <TextBlock Style="{StaticResource SectionHeader}" Text="We'd love to hear from you" />
                        <Button
                            Width="180"
                            Margin="0,0,0,10"
                            Padding="15,10"
                            HorizontalAlignment="Left"
                            Click="AskAQuestion_Click"
                            Content="Ask a question" />
                        <Button
                            Width="180"
                            Padding="15,10"
                            HorizontalAlignment="Left"
                            Click="SuggestAnIdea_Click"
                            Content="I have a suggestion" />
                    </StackPanel>
                </Grid>
            </TabItem>

        </TabControl>
    </Grid>
</Window>